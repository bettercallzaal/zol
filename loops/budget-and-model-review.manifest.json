{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "budget-and-model-review-v1",
  "title": "Budget and Model Review",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "daily or when budget threshold reached",
  "inputs": [
    "current date",
    "budget ceiling (env or state)"
  ],
  "context_sources": [
    "daily token consumption log",
    "model performance metrics (receipts)",
    "OpenRouter current rate limits"
  ],
  "allowed_actions": [
    "budget.read",
    "model.usage.read",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "budget data available",
    "model usage queryable",
    "ceiling not exceeded"
  ],
  "evidence_outputs": [
    "budget-review-timestamp",
    "tokens-used-today",
    "tokens-remaining",
    "daily-burn-rate"
  ],
  "receipt_outputs": [
    "budget-and-model-review receipt"
  ],
  "knowledge_state_outputs": [
    "budget status current",
    "model performance tracked"
  ],
  "execution_trace_outputs": [
    "budget-and-model-review trace"
  ],
  "memory_routes": [
    "durable: daily burn patterns"
  ],
  "cooldown": "3600s (hourly check optional)",
  "failure_modes": [
    "budget env var missing",
    "model usage API timeout",
    "ceiling exceeded (flag, do not escalate)"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 90000,
    "max_steps": 4,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-budget",
      "handler": "budget.read",
      "permission": "budget.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-model-usage",
      "handler": "model.usage.read",
      "permission": "model.usage.read",
      "with": {
        "model": "claude-fable-5"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "update-budget-state",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-budget-state"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-budget-review",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "budget-and-model-review"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ]
}
