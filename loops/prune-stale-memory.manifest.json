{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "prune-stale-memory-v1",
  "title": "Prune Stale Memory",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "weekly or operator request",
  "inputs": [
    "full memory store",
    "memory age metadata"
  ],
  "context_sources": [
    "all memory entries",
    "memory timestamps"
  ],
  "allowed_actions": [
    "memory.expire",
    "memory.read",
    "receipt.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "memory readable",
    "expiry safe to execute"
  ],
  "evidence_outputs": [
    "memory-entries-scanned",
    "entries-expired"
  ],
  "receipt_outputs": [
    "prune-stale-memory receipt"
  ],
  "knowledge_state_outputs": [
    "stale memory entries expired"
  ],
  "execution_trace_outputs": [
    "prune-stale-memory execution trace"
  ],
  "memory_routes": [
    "expiry log in memory store"
  ],
  "cooldown": "604800s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "full"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "expire-stale",
      "handler": "memory.expire",
      "permission": "memory.expire",
      "with": {
        "policy": "stale"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "prune-stale-memory"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
