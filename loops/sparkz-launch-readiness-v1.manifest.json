{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "sparkz-launch-readiness-v1",
  "title": "Sparkz Launch Readiness Assessment",
  "version": "1.0.0",
  "status": "active",
  "owner": "zolbot",
  "stewards": ["zaal"],
  "permission_tier": "read_only",
  "trigger": "on-demand or weekly per creator request",
  "cooldown": "3600s",
  "description": "Compute an energy score (0-100) for a creator's Farcaster presence and output a launch-readiness recommendation (launch_now / keep_building / insufficient_data). Reads follower growth, cast engagement, and channel activity via Neynar API. Falls back to mock data in dev. No posting, no wallet actions.",
  "allowed_actions": [
    "farcaster.follower-growth-read",
    "farcaster.cast-engagement-read",
    "farcaster.channel-activity-read",
    "energy-score.compute",
    "energy-score.launch-recommendation",
    "energy-score.trend-analysis",
    "state.energy-history-write",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cast.post.without_approval",
    "cloud.mutate",
    "deployment.production.write",
    "farcaster.post",
    "farcaster.reply",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "signer.change",
    "wallet.sign"
  ],
  "entry_conditions": [
    "agent_running",
    "creator_fid_provided"
  ],
  "exit_conditions": [
    "recommendation_produced",
    "receipt_recorded"
  ],
  "retry_limits": {
    "max_retries": 2,
    "backoff_ms": 5000
  },
  "escalation_rules": [
    "log:error",
    "notify:owner:telegram",
    "return:insufficient_data"
  ],
  "limits": {
    "max_wall_time_ms": 30000,
    "max_steps": 8,
    "max_retries_per_step": 2
  },
  "promotion_path": "prototype -> dry_run -> active_local -> live_guarded",
  "last_reviewed": "2026-07-17",
  "steps": [
    {
      "id": "read-follower-growth",
      "handler": "farcaster.follower-growth-read",
      "permission": "farcaster.follower-growth-read",
      "with": { "days": 7 },
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "read-cast-engagement",
      "handler": "farcaster.cast-engagement-read",
      "permission": "farcaster.cast-engagement-read",
      "with": { "days": 7 },
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "read-channel-activity",
      "handler": "farcaster.channel-activity-read",
      "permission": "farcaster.channel-activity-read",
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "compute-energy-score",
      "handler": "energy-score.compute",
      "permission": "energy-score.compute",
      "retry": { "max_attempts": 1 }
    },
    {
      "id": "generate-recommendation",
      "handler": "energy-score.launch-recommendation",
      "permission": "energy-score.launch-recommendation",
      "retry": { "max_attempts": 1 }
    },
    {
      "id": "analyze-trend",
      "handler": "energy-score.trend-analysis",
      "permission": "energy-score.trend-analysis",
      "retry": { "max_attempts": 1 }
    },
    {
      "id": "write-energy-history",
      "handler": "state.energy-history-write",
      "permission": "state.energy-history-write",
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "write-receipt",
      "handler": "receipt.launch-recommendation-write",
      "permission": "receipt.local.write",
      "retry": { "max_attempts": 2 }
    }
  ],
  "lifecycle_state": "dry-run",
  "failure_modes": [
    "Neynar key missing: falls back to mock data, recommendation still produced",
    "creatorFid not provided: loop fails at entry condition",
    "Energy score computation error: escalate to operator"
  ],
  "inputs": ["creatorFid (required)", "days (optional, default 7)", "priorScores (optional history array)"],
  "context_sources": ["neynar_api", "local_state"],
  "checks": ["creator_fid_provided"],
  "evidence_outputs": ["energy_score", "recommendation", "component_scores", "trend"],
  "receipt_outputs": ["launch-recommendation-receipt.json"],
  "knowledge_state_outputs": ["energy-history:{creatorFid}"],
  "execution_trace_outputs": ["sparkz-launch-readiness.trace.json"],
  "memory_routes": [
    "energy-history:{creatorFid} -> state.local"
  ]
}
