{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "component-radar-v1",
  "title": "Component Radar",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "read_only",
  "trigger": "periodic scan (weekly or operator request)",
  "inputs": [
    "component type (music player, social, etc.)",
    "scan depth (shallow, full)"
  ],
  "context_sources": [
    "recent component status (if available)",
    "operator alerts or requests"
  ],
  "allowed_actions": [
    "receipt.local.write",
    "source.public.read",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "component type valid",
    "sources accessible"
  ],
  "evidence_outputs": [
    "radar-scan-timestamp",
    "component-count",
    "status-summary"
  ],
  "receipt_outputs": [
    "component-radar receipt"
  ],
  "knowledge_state_outputs": [
    "component inventory updated"
  ],
  "execution_trace_outputs": [
    "component-radar trace"
  ],
  "memory_routes": [
    "durable: component status tracking"
  ],
  "cooldown": "604800s (weekly)",
  "failure_modes": [
    "sources unreachable",
    "component list incomplete",
    "scan timeout"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 180000,
    "max_steps": 3,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "scan-components",
      "handler": "source.public.read",
      "permission": "source.public.read",
      "with": {
        "scope": "component-registry"
      },
      "retry": {
        "max_attempts": 3
      }
    },
    {
      "id": "read-component-state",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-component-inventory"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-radar",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "component-radar"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ]
}
