{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "community-wins-spotlight-v1",
  "title": "Community Wins Spotlight",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zol-curator-v1",
  "stewards": ["zaal"],
  "permission_tier": "draft_write_only",
  "trigger": "daily at 6:30am (30 minutes after morning-plan, after Zaal reads overnight wins)",
  "inputs": [
    "current date",
    "Bonfire shared-graph episodes from last 24h",
    "ZAO community context (ICM boxes)",
    "operator preference (celebration style)"
  ],
  "context_sources": [
    "Bonfire delve query for community wins/achievements",
    "ZAO ecosystem boxes (useicm.com)",
    "recent receipts from other agents (ZOE orchestrator, ZOL discovers)"
  ],
  "allowed_actions": [
    "bonfire.delve",
    "farcaster.read",
    "memory.read",
    "memory.write",
    "artifact.draft.write",
    "receipt.local.write",
    "approval.request"
  ],
  "blocked_actions": [
    "farcaster.post",
    "farcaster.autoupload",
    "fund.transfer",
    "wallet.sign",
    "deployment.production.write",
    "signer.change",
    "secret.value.read"
  ],
  "checks": [
    "Bonfire API available",
    "date boundary enforced",
    "no secrets in draft",
    "draft file permissions 0600"
  ],
  "evidence_outputs": [
    "wins-found-count",
    "patterns-detected",
    "cast-quality-score",
    "celebration-style-used"
  ],
  "receipt_outputs": [
    "wins-spotlight-receipt"
  ],
  "knowledge_state_outputs": [
    "today-wins-discovered",
    "community-patterns-observed",
    "celebration-draft-stored"
  ],
  "execution_trace_outputs": [
    "wins-spotlight-execution-trace"
  ],
  "memory_routes": [
    "episodic: today's wins and celebrates",
    "durable: celebration patterns that land with Zaal"
  ],
  "cooldown": "86400s (daily)",
  "failure_modes": [
    "Bonfire API unavailable",
    "no wins found (skip gracefully)",
    "LLM timeout on draft generation",
    "memory write failed",
    "permission denied on draft write"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 180000,
    "max_steps": 8,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "query-bonfire-wins",
      "handler": "bonfire.delve",
      "permission": "bonfire.delve",
      "with": {
        "query": "community wins, achievements, breakthroughs, launches from last 24 hours"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "parse-win-episodes",
      "handler": "win-pattern.parse",
      "permission": "memory.read",
      "with": {
        "scoreThreshold": 0.7,
        "excludeAutomatic": false
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "detect-patterns",
      "handler": "win-pattern.detect",
      "permission": "memory.read",
      "with": {
        "method": "cross-agent-signals"
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "load-zao-context",
      "handler": "context.icm-load",
      "permission": "farcaster.read",
      "with": {
        "boxes": ["zao-assistant", "thezao", "bettercallzaal"]
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "draft-celebration",
      "handler": "draft.compose",
      "permission": "artifact.draft.write",
      "with": {
        "style": "genuine-joyful",
        "timeout_ms": 45000
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "validate-draft",
      "handler": "draft.validate",
      "permission": "artifact.draft.write",
      "with": {
        "checkSecrets": true,
        "checkLength": true
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "store-draft",
      "handler": "artifact.store",
      "permission": "artifact.draft.write",
      "with": {
        "draftType": "wins-spotlight"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "wins-spotlight"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ]
}
