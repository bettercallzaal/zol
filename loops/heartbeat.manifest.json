{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "heartbeat-v1",
  "title": "Heartbeat",
  "version": "1.0.0",
  "status": "active",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "every 30 minutes",
  "cooldown": "1800s",
  "description": "Check agent health, record liveness receipt, update last-seen timestamp in state.",
  "allowed_actions": [
    "budget.read",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-17",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-health",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "check-budget",
      "handler": "budget.read",
      "permission": "budget.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-liveness",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-heartbeat",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "production-ready",
  "entry_conditions": [
    "agent_running"
  ],
  "exit_conditions": [
    "heartbeat_recorded",
    "last_seen_updated"
  ],
  "retry_limits": {
    "max_retries": 1,
    "backoff_ms": 500
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ],
  "inputs": [],
  "context_sources": [
    "local state store",
    "last-seen timestamp"
  ],
  "checks": [
    "state_store_writable",
    "liveness_receipt_written"
  ],
  "evidence_outputs": [
    "liveness_timestamp"
  ],
  "receipt_outputs": [
    "heartbeat-receipt"
  ],
  "knowledge_state_outputs": [],
  "execution_trace_outputs": [],
  "memory_routes": []
}
