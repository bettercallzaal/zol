{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "field-test-v1",
  "title": "Field Test",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "after tool-workout completes, to verify real tool behavior",
  "inputs": [
    "tool-workout result artifact",
    "field test criteria",
    "budget snapshot"
  ],
  "context_sources": [
    "workout evidence store",
    "field test criteria config",
    "budget ledger"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "budget.read",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "workout result readable and valid",
    "field test criteria defined",
    "evidence artifact written successfully",
    "budget not exceeded during test"
  ],
  "evidence_outputs": [
    "field test result artifact",
    "pass/fail determination",
    "real tool behavior log"
  ],
  "receipt_outputs": [
    "field-test receipt"
  ],
  "knowledge_state_outputs": [
    "field test outcome recorded",
    "real tool behavior evidence archived"
  ],
  "execution_trace_outputs": [
    "field-test execution trace"
  ],
  "memory_routes": [
    "episodic: field test outcomes",
    "durable: verified tool behavior history"
  ],
  "cooldown": "86400s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-workout-result",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "tool-workout-evidence",
        "requireStatus": "complete"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "run-field-test",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "field-test-criteria"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-evidence",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {
        "artifactType": "field-test-evidence",
        "draftOnly": false
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "field-test"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
