{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "deliver-and-receipt-v1",
  "title": "Deliver and Receipt",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "after trapper packaged and approval received",
  "inputs": [
    "trapper package reference",
    "approval token",
    "delivery target"
  ],
  "context_sources": [
    "package manifest state store",
    "approval record",
    "delivery target configuration"
  ],
  "allowed_actions": [
    "approval.request",
    "artifact.local.write",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "artifact is packaged and verified",
    "approval obtained prior to delivery",
    "work packet closeable",
    "receipt written successfully"
  ],
  "evidence_outputs": [
    "delivery confirmation",
    "closed packet reference",
    "delivery timestamp"
  ],
  "receipt_outputs": [
    "deliver-and-receipt receipt"
  ],
  "knowledge_state_outputs": [
    "artifact delivered",
    "work packet closed"
  ],
  "execution_trace_outputs": [
    "deliver-and-receipt execution trace"
  ],
  "memory_routes": [
    "episodic: delivery events",
    "durable: closed work packets log"
  ],
  "cooldown": "300s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-artifact",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "trapper-package"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "verify-artifact",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "verification-result",
        "requireStatus": "passed"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "deliver",
      "handler": "approval.request",
      "permission": "approval.request",
      "with": {
        "approvalType": "delivery-gate",
        "requiredApprover": "zaal"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "close-packet",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "work-packet",
        "updateStatus": "closed"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "deliver-and-receipt"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
