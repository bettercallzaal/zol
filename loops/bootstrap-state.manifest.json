{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "bootstrap-state-v1",
  "title": "Bootstrap State",
  "version": "1.0.0",
  "status": "active",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "on first startup or after state reset",
  "cooldown": "86400s",
  "description": "Initialize durable state, validate capsule registry, seed default memory structures, and record bootstrap receipt.",
  "allowed_actions": [
    "memory.write",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "init-state-store",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "load-capsule-registry",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "validate-registry",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "seed-memory",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-bootstrap",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "production-ready",
  "entry_conditions": [
    "agent_cold_start",
    "state_uninitialized"
  ],
  "exit_conditions": [
    "state_seeded",
    "capsule_registry_validated"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ],
  "inputs": [],
  "context_sources": [],
  "checks": [],
  "evidence_outputs": [],
  "receipt_outputs": [],
  "knowledge_state_outputs": [],
  "execution_trace_outputs": [],
  "memory_routes": []
}
