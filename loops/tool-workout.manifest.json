{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "tool-workout-v1",
  "title": "Tool Workout",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "scheduled ToolGym session or operator request",
  "inputs": [
    "ToolGym workout manifest",
    "budget snapshot",
    "prior workout results (if any)"
  ],
  "context_sources": [
    "ToolGym workout manifest store",
    "budget ledger",
    "evidence archive"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "budget.read",
    "receipt.local.write",
    "state.local.read",
    "toolgym.workout.run"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "workout manifest valid and readable",
    "budget sufficient for workout",
    "workout not already completed for session",
    "evidence written successfully"
  ],
  "evidence_outputs": [
    "workout run results",
    "tool performance metrics",
    "evidence artifact"
  ],
  "receipt_outputs": [
    "tool-workout receipt"
  ],
  "knowledge_state_outputs": [
    "workout session recorded",
    "tool performance evidence archived"
  ],
  "execution_trace_outputs": [
    "tool-workout execution trace"
  ],
  "memory_routes": [
    "episodic: workout session events",
    "durable: tool performance history"
  ],
  "cooldown": "86400s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-manifest",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "toolgym-workout-manifest"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-budget",
      "handler": "budget.read",
      "permission": "budget.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "run-workout",
      "handler": "toolgym.workout.run",
      "permission": "toolgym.workout.run",
      "with": {
        "workoutScope": "scheduled-session"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-evidence",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {
        "artifactType": "tool-workout-evidence",
        "draftOnly": false
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "tool-workout"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
