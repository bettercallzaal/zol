{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "community-wins-spotlight-v1",
  "title": "Community Wins Spotlight",
  "version": "1.0.0",
  "status": "active",
  "owner": "zolbot",
  "stewards": ["zaal"],
  "permission_tier": "artifact_draft_write",
  "trigger": "daily at 6:30am (30 minutes after morning-plan)",
  "cooldown": "21600s",
  "description": "Discover underappreciated wins from the ZAO ecosystem via local receipts and state. Detect dominant themes (music focus, builder energy, web3 momentum, community vibes). Draft a genuine celebration cast — draft-only, Telegram-gated before any public post. Bonfire shared-graph integration deferred until Bonfire access is available; falls back to local receipt state.",
  "allowed_actions": [
    "community.wins.spot",
    "artifact.draft.write",
    "memory.read",
    "memory.write",
    "receipt.local.read",
    "receipt.local.write",
    "state.local.read",
    "state.local.write",
    "telegram.approval.request"
  ],
  "blocked_actions": [
    "bonfire.delve",
    "cast.post.without_approval",
    "cloud.mutate",
    "deployment.production.write",
    "farcaster.post",
    "farcaster.reply",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "signer.change",
    "wallet.sign"
  ],
  "entry_conditions": [
    "agent_running",
    "state_readable",
    "local_receipts_available"
  ],
  "exit_conditions": [
    "draft_stored_or_no_wins",
    "receipt_recorded"
  ],
  "retry_limits": {
    "max_retries": 2,
    "backoff_ms": 5000
  },
  "escalation_rules": [
    "log:error",
    "notify:owner:telegram",
    "store:no_wins_found_receipt"
  ],
  "limits": {
    "max_wall_time_ms": 30000,
    "max_steps": 5,
    "max_retries_per_step": 2,
    "max_draft_length_chars": 280,
    "day_cap": 1
  },
  "promotion_path": "prototype -> rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-17",
  "steps": [
    {
      "id": "spot-wins",
      "handler": "community.wins.spot",
      "permission": "community.wins.spot",
      "with": {},
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "store-draft",
      "handler": "artifact.draft.write",
      "permission": "artifact.draft.write",
      "with": { "type": "celebration_cast" },
      "conditional": "previous_step.winsFound > 0",
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "request-approval",
      "handler": "telegram.approval.request",
      "permission": "telegram.approval.request",
      "with": {
        "action_type": "cast.celebration.draft",
        "message_template": "ZOL found wins worth celebrating today. Review draft and approve to schedule."
      },
      "conditional": "previous_step.winsFound > 0",
      "retry": { "max_attempts": 1 }
    },
    {
      "id": "update-memory",
      "handler": "memory.write",
      "permission": "memory.write",
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "retry": { "max_attempts": 2 }
    }
  ],
  "lifecycle_state": "dry-run",
  "failure_modes": [
    "No local receipts found: ok:true, winsFound:0, no draft produced, receipt written",
    "Draft contains secret: validation fails, draft discarded, error receipt written",
    "Approval request fails: draft stored locally, no cast scheduled"
  ],
  "inputs": ["episodes (optional array of win episodes; falls back to local receipts)"],
  "context_sources": ["local_receipts", "local_state", "bonfire_optional"],
  "checks": ["state_readable"],
  "evidence_outputs": ["wins_found_count", "patterns_detected", "draft_quality_valid"],
  "receipt_outputs": ["wins-spotlight-receipt.json"],
  "knowledge_state_outputs": ["today-wins-discovered", "community-patterns-observed"],
  "execution_trace_outputs": ["wins-spotlight.trace.json"],
  "memory_routes": [
    "community-patterns -> memory.episodic",
    "wins-spotlight.draft -> state.local"
  ]
}
