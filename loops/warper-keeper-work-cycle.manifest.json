{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "warper-keeper-work-cycle-v1",
  "title": "Warper Keeper Work Cycle",
  "version": "1.0.0",
  "status": "draft",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "artifact_draft_write",
  "trigger": "DISABLED PHASE 5: operator initiates warper/keeper work (music curation, research deep dives)",
  "inputs": [
    "work type (warper, keeper)",
    "source material or topic"
  ],
  "context_sources": [
    "ZOL's music taste profile (memory)",
    "recent warper/keeper work (receipts)",
    "artist/release metadata"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "source.public.read",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "work type (warper or keeper) specified",
    "source material accessible",
    "taste profile available"
  ],
  "evidence_outputs": [
    "work-cycle-id",
    "work-type",
    "artifact-count",
    "curator-notes"
  ],
  "receipt_outputs": [
    "warper-keeper-work-cycle receipt"
  ],
  "knowledge_state_outputs": [
    "curation work staged",
    "taste notes recorded"
  ],
  "execution_trace_outputs": [
    "warper-keeper-work-cycle trace"
  ],
  "memory_routes": [
    "episodic: per-work decision log",
    "durable: taste profile evolution"
  ],
  "cooldown": "per-work (no cooldown)",
  "failure_modes": [
    "source unavailable",
    "taste data missing",
    "artifact write failed"
  ],
  "promotion_path": "draft -> rehearsed -> active_local (PHASE 5)",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 1200000,
    "max_steps": 5,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-taste-profile",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "zol-taste-profile"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-source-material",
      "handler": "source.public.read",
      "permission": "source.public.read",
      "with": {
        "scope": "music-metadata"
      },
      "retry": {
        "max_attempts": 3
      }
    },
    {
      "id": "stage-curation-work",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {
        "artifactType": "warper-keeper-curation"
      },
      "retry": {
        "max_attempts": 3
      }
    },
    {
      "id": "update-taste-notes",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "memoryType": "curation-notes"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-work-cycle",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "warper-keeper-work-cycle"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "specification-only",
  "entry_conditions": [
    "warper_assignment_accepted",
    "keeper_context_loaded"
  ],
  "exit_conditions": [
    "work_cycle_complete",
    "cycle_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
