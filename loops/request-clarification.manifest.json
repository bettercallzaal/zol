{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "request-clarification-v1",
  "title": "Request Clarification",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "when detect-work-intent flags incomplete request",
  "inputs": [
    "incomplete work packet",
    "intent classification"
  ],
  "context_sources": [
    "local state"
  ],
  "allowed_actions": [
    "approval.request",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "work packet readable",
    "clarification draft safe to send"
  ],
  "evidence_outputs": [
    "work-packet-id",
    "clarification-draft",
    "approval-request-sent"
  ],
  "receipt_outputs": [
    "request-clarification receipt"
  ],
  "knowledge_state_outputs": [
    "clarification approval requested"
  ],
  "execution_trace_outputs": [
    "request-clarification execution trace"
  ],
  "memory_routes": [
    "clarification request log in local state"
  ],
  "cooldown": "300s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-work-packet",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-work-packet"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "draft-clarification",
      "handler": "approval.request",
      "permission": "approval.request",
      "with": {
        "approvalType": "clarification-request"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "request-clarification"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "ambiguity_detected",
    "clarification_recipient_available"
  ],
  "exit_conditions": [
    "clarification_sent",
    "response_received OR timeout"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
