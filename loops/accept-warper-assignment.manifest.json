{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "accept-warper-assignment-v1",
  "title": "Accept Warper Assignment",
  "version": "1.0.0",
  "status": "draft",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "on incoming Warper Keeper assignment notification",
  "inputs": [
    "Warper Keeper assignment notification",
    "assignment metadata",
    "current agent capacity state"
  ],
  "context_sources": [
    "Warper Keeper assignment queue",
    "agent capacity state store",
    "assignment validation rules"
  ],
  "allowed_actions": [
    "approval.request",
    "receipt.local.write",
    "state.local.read",
    "state.local.write",
    "warper.assignment.accept"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "assignment notification is valid",
    "agent has capacity for assignment",
    "assignment not already accepted",
    "acceptance confirmation received"
  ],
  "evidence_outputs": [
    "assignment acceptance confirmation",
    "assignment metadata snapshot",
    "acceptance timestamp"
  ],
  "receipt_outputs": [
    "accept-warper-assignment receipt"
  ],
  "knowledge_state_outputs": [
    "Warper assignment accepted",
    "agent capacity state updated"
  ],
  "execution_trace_outputs": [
    "accept-warper-assignment execution trace"
  ],
  "memory_routes": [
    "episodic: assignment acceptance events",
    "durable: active Warper assignments log"
  ],
  "cooldown": "300s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-assignment",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "warper-keeper-assignment",
        "source": "incoming-notification"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "validate-assignment",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "agent-capacity",
        "validateAgainst": "warper-assignment-rules"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "accept-assignment",
      "handler": "warper.assignment.accept",
      "permission": "warper.assignment.accept",
      "with": {
        "assignmentSource": "warper-keeper"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "accept-warper-assignment"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "warper_assignment_available",
    "keeper_available"
  ],
  "exit_conditions": [
    "assignment_accepted",
    "contract_recorded"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
