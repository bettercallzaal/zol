{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "relationship-sync-v1",
  "title": "Relationship Sync",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "after inbox-triage, after a new mention or follow event, or on operator request",
  "cooldown": "300s",
  "description": "Sync relationship state with memory: read current relationship data, reconcile with stored relationship memory, update the relationship index, and record a sync receipt.",
  "allowed_actions": [
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "relationship.read",
    "relationship.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-relationship-state",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-relationship-index"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-relationship-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "type": "relationship"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "reconcile-and-write",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "type": "relationship",
        "mergeStrategy": "timestamp-latest"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "update-index",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-relationship-index"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-sync-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "relationship-sync"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "relationship_event_detected",
    "relationship_memory_accessible"
  ],
  "exit_conditions": [
    "relationship_index_updated",
    "sync_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ],
  "inputs": [],
  "context_sources": [],
  "checks": [],
  "evidence_outputs": [],
  "receipt_outputs": [],
  "knowledge_state_outputs": [],
  "execution_trace_outputs": [],
  "memory_routes": []
}
