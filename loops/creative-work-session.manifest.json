{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "creative-work-session-v1",
  "title": "Creative Work Session",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "operator initiates creative work (writing, curation, design)",
  "inputs": [
    "work type (post, curation, discovery)",
    "source material or topic"
  ],
  "context_sources": [
    "ZOL's voice and tone (memory)",
    "recent similar work (receipts)",
    "audience context (relationships)",
    "time budget available"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "memory.read",
    "receipt.local.write",
    "relationship.read",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "work type recognized",
    "source material provided",
    "voice consistency maintainable"
  ],
  "evidence_outputs": [
    "work-session-id",
    "work-type",
    "artifact-count",
    "session-duration"
  ],
  "receipt_outputs": [
    "creative-work-session receipt"
  ],
  "knowledge_state_outputs": [
    "creative session active",
    "artifacts staged"
  ],
  "execution_trace_outputs": [
    "creative-work-session trace"
  ],
  "memory_routes": [
    "episodic: session log",
    "durable: voice consistency patterns"
  ],
  "cooldown": "per-session (no cooldown)",
  "failure_modes": [
    "source unavailable",
    "artifact write failed",
    "voice consistency check failed"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 900000,
    "max_steps": 5,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-voice-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "zol-voice-tone"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-audience",
      "handler": "relationship.read",
      "permission": "relationship.read",
      "with": {
        "full": true
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "stage-artifacts",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {
        "artifactType": "creative-work"
      },
      "retry": {
        "max_attempts": 3
      }
    },
    {
      "id": "update-work-state",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-creative-work-session"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-session",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "creative-work-session"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ]
}
