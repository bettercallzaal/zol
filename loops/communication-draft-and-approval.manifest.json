{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "communication-draft-and-approval-v1",
  "title": "Communication Draft and Approval",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "artifact_draft_write",
  "trigger": "new draft to review or operator request",
  "inputs": [
    "draft message (text, embeds, mentions)",
    "target platform (Farcaster only)",
    "original trigger (event, mention, plan)"
  ],
  "context_sources": [
    "ZOL's recent voice/tone (memory)",
    "target audience context (relationship state)",
    "previous similar posts (receipts)",
    "Farcaster conversation thread (if reply)"
  ],
  "allowed_actions": [
    "approval.request",
    "artifact.local.write",
    "farcaster.reply",
    "memory.read",
    "receipt.local.write",
    "relationship.read",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "farcaster.autoupload",
    "fund.transfer",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "draft text <= 320 chars (Farcaster)",
    "no @ mentions that would trigger other bots (Zaal's rule)",
    "draft.ready === true before proceeding to approval",
    "approval gate response received before publish"
  ],
  "evidence_outputs": [
    "draft-id",
    "draft-text (cleaned)",
    "approval-status",
    "approval-timestamp"
  ],
  "receipt_outputs": [
    "communication draft receipt"
  ],
  "knowledge_state_outputs": [
    "draft staged",
    "approval requested",
    "post approved (or rejected)"
  ],
  "execution_trace_outputs": [
    "communication-draft execution trace"
  ],
  "memory_routes": [
    "episodic: per-draft decision",
    "durable: approval patterns"
  ],
  "cooldown": "as-needed (triggered by draft submission)",
  "failure_modes": [
    "approval timeout",
    "approval denied (retry or abandon)",
    "draft invalid (text too long, chars invalid)",
    "Farcaster API error (PHASE 5)"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded (requires Telegram approval gate)",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 300000,
    "max_steps": 7,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "validate-draft",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {
        "artifactType": "draft",
        "validateText": true,
        "maxLength": 320
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "read-context-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "maxRecent": 2,
        "scope": "recent-voice-tone"
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "read-relationship",
      "handler": "relationship.read",
      "permission": "relationship.read",
      "with": {
        "includeMuted": false
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "request-approval",
      "handler": "approval.request",
      "permission": "approval.request",
      "with": {
        "channel": "telegram",
        "operatorId": "zaal",
        "timeoutSec": 600,
        "requireExplicitApproval": true
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "stage-draft",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-staged-draft",
        "includeApprovalStatus": true
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "post-if-approved",
      "handler": "farcaster.reply",
      "permission": "farcaster.reply",
      "with": {
        "requireApprovalToken": true,
        "draftFromState": "zol-staged-draft"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-communication",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "communication-draft-and-approval"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "communication_intent_detected",
    "draft_ready"
  ],
  "exit_conditions": [
    "communication_approved OR communication_denied"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 3000
  },
  "escalation_rules": [
    "deny:action",
    "notify:owner",
    "log:error"
  ]
}
