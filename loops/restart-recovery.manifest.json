{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "restart-recovery-v1",
  "title": "Restart Recovery",
  "version": "1.0.0",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "on daemon restart, after crash or SIGTERM, or when resume-work finds checkpoint",
  "cooldown": "60s",
  "description": "Detect interrupted work packets, resume from last checkpoint, re-queue failed tasks, and emit recovery receipt.",
  "allowed_actions": [
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-checkpoint",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "detect-interrupted",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "resume-packets",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "re-queue-failed",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "emit-recovery",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "production-ready",
  "entry_conditions": [
    "agent_restart_detected",
    "interrupted_work_exists"
  ],
  "exit_conditions": [
    "work_resumed_or_requeued",
    "recovery_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 2,
    "backoff_ms": 2000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
