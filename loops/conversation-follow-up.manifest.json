{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "conversation-follow-up-v1",
  "title": "Conversation Follow-Up",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "24h after conversation with relationship contact",
  "inputs": [
    "relationship contact record",
    "conversation history",
    "follow-up state"
  ],
  "context_sources": [
    "relationship store",
    "local state",
    "memory"
  ],
  "allowed_actions": [
    "approval.request",
    "memory.read",
    "receipt.local.write",
    "relationship.read",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "relationship readable",
    "follow-up state accessible",
    "approval request safe"
  ],
  "evidence_outputs": [
    "relationship-contact-read",
    "follow-up-needed-flag",
    "approval-request-sent"
  ],
  "receipt_outputs": [
    "conversation-follow-up receipt"
  ],
  "knowledge_state_outputs": [
    "follow-up approval requested"
  ],
  "execution_trace_outputs": [
    "conversation-follow-up execution trace"
  ],
  "memory_routes": [
    "follow-up log in local state"
  ],
  "cooldown": "86400s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-relationship",
      "handler": "relationship.read",
      "permission": "relationship.read",
      "with": {
        "scope": "recent-conversations"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "check-follow-up-needed",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-follow-up-state"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "request-approval",
      "handler": "approval.request",
      "permission": "approval.request",
      "with": {
        "approvalType": "conversation-follow-up"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "conversation-follow-up"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "open_conversation_exists",
    "follow_up_due"
  ],
  "exit_conditions": [
    "follow_up_drafted",
    "follow_up_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
