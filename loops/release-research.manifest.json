{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "release-research-v1",
  "title": "Release Research",
  "version": "1.0.0",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "before curator-brief on specific artist",
  "inputs": [
    "artist state",
    "release data source"
  ],
  "context_sources": [
    "local state",
    "memory"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "memory.read",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "artist state readable",
    "release data accessible",
    "findings artifact writable"
  ],
  "evidence_outputs": [
    "artist-read",
    "releases-researched",
    "findings-artifact-id"
  ],
  "receipt_outputs": [
    "release-research receipt"
  ],
  "knowledge_state_outputs": [
    "release findings artifact written"
  ],
  "execution_trace_outputs": [
    "release-research execution trace"
  ],
  "memory_routes": [
    "release findings artifact stored locally"
  ],
  "cooldown": "3600s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-artist",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-artist-state"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "research-releases",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-release-data"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-findings",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {
        "artifactType": "release-research-findings"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "release-research"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "release_research_triggered",
    "target_release_defined"
  ],
  "exit_conditions": [
    "research_artifact_written",
    "research_receipt_logged"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
