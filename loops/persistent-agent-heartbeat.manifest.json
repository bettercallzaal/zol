{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "persistent-agent-heartbeat-v1",
  "title": "Persistent Agent Heartbeat",
  "version": "1.0.0",
  "status": "active",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "periodic (hourly or operator request)",
  "inputs": [
    "current timestamp",
    "uptime duration",
    "last checkpoint age"
  ],
  "context_sources": [
    "runtime state",
    "budget consumption",
    "error logs from receipts"
  ],
  "allowed_actions": [
    "budget.read",
    "memory.read",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "process alive",
    "budget OK",
    "state consistent",
    "last heartbeat < 1h old"
  ],
  "evidence_outputs": [
    "heartbeat-timestamp",
    "uptime-seconds",
    "budget-consumed-tokens",
    "error-count-since-last"
  ],
  "receipt_outputs": [
    "heartbeat receipt"
  ],
  "knowledge_state_outputs": [
    "heartbeat timestamp recorded",
    "budget state refreshed"
  ],
  "execution_trace_outputs": [
    "heartbeat execution trace"
  ],
  "memory_routes": [
    "transient heartbeat log",
    "only last 24h kept"
  ],
  "cooldown": "3600s (1 hour)",
  "failure_modes": [
    "budget exceeded",
    "state corruption",
    "memory unavailable",
    "timeout"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 4,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "check-budget",
      "handler": "budget.read",
      "permission": "budget.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-state",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-runtime-state"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "update-heartbeat",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-heartbeat-log"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-heartbeat",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "heartbeat"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "production-ready",
  "entry_conditions": [
    "agent_running",
    "schedule_tick"
  ],
  "exit_conditions": [
    "heartbeat_recorded",
    "liveness_confirmed"
  ],
  "retry_limits": {
    "max_retries": 1,
    "backoff_ms": 500
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
