{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "board-triage-nightly-v1",
  "title": "Board Triage Nightly",
  "version": "1.0.0",
  "status": "active",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "every 24 hours at 02:00 local",
  "cooldown": "43200s",
  "description": "Nightly cowork-board hygiene: scan all open rows, close shipped items, dedup title-matches, surface the unblocked top-10 by priority, and emit a receipt so Zaal sees an honest board at morning review.",
  "allowed_actions": [
    "board.task.find",
    "board.task.list-open",
    "board.task.update",
    "board.task.finish",
    "board.triage.run",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "board.task.create",
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "failure_modes": [
    "board API unreachable",
    "timeout",
    "duplicate detection false positive",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 10,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "run-triage-analysis",
      "handler": "board.triage.run",
      "permission": "board.triage.run",
      "with": { "topN": 10 },
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "update-duplicate-notes",
      "handler": "board.task.update",
      "permission": "board.task.update",
      "with": {},
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "write-triage-state",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": { "max_attempts": 2 }
    },
    {
      "id": "record-triage-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": { "max_attempts": 2 }
    }
  ],
  "lifecycle_state": "production-ready",
  "entry_conditions": [
    "agent_running",
    "board_api_reachable"
  ],
  "exit_conditions": [
    "triage_receipt_written",
    "open_rows_reviewed"
  ],
  "retry_limits": {
    "max_retries": 2,
    "backoff_ms": 5000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "continue_partial"
  ],
  "inputs": [],
  "context_sources": [
    "cowork_board"
  ],
  "checks": [
    "board_api_reachable"
  ],
  "evidence_outputs": [
    "triage_receipt"
  ],
  "receipt_outputs": [
    "board-triage-nightly.receipt.json"
  ],
  "knowledge_state_outputs": [
    "board.top10"
  ],
  "execution_trace_outputs": [
    "board-triage-nightly.trace.json"
  ],
  "memory_routes": []
}
