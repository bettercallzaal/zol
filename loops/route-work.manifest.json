{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "route-work-v1",
  "title": "Route Work",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "after work packet created",
  "inputs": [
    "work packet",
    "priority context"
  ],
  "context_sources": [
    "local state"
  ],
  "allowed_actions": [
    "priority.plan",
    "receipt.local.write",
    "state.local.read",
    "state.local.write",
    "task.plan"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "work packet readable",
    "priority plan available",
    "route writable"
  ],
  "evidence_outputs": [
    "work-packet-id",
    "priority-score",
    "assigned-route"
  ],
  "receipt_outputs": [
    "route-work receipt"
  ],
  "knowledge_state_outputs": [
    "route assignment written to state"
  ],
  "execution_trace_outputs": [
    "route-work execution trace"
  ],
  "memory_routes": [
    "route assignment in local state"
  ],
  "cooldown": "60s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-packet",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-work-packet"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "prioritize",
      "handler": "priority.plan",
      "permission": "priority.plan",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "assign-route",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-work-route"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "route-work"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "work_packet_created",
    "routing_rules_available"
  ],
  "exit_conditions": [
    "work_routed",
    "routing_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
