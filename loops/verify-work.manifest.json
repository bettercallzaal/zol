{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "verify-work-v1",
  "title": "Verify Work",
  "version": "1.0.0",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "after task completion before close",
  "inputs": [
    "work packet",
    "task artifact",
    "evidence records"
  ],
  "context_sources": [
    "local state",
    "artifact store"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "work packet readable",
    "artifact accessible",
    "evidence readable"
  ],
  "evidence_outputs": [
    "work-packet-id",
    "artifact-verified",
    "evidence-checked"
  ],
  "receipt_outputs": [
    "verify-work receipt"
  ],
  "knowledge_state_outputs": [
    "verification result recorded"
  ],
  "execution_trace_outputs": [
    "verify-work execution trace"
  ],
  "memory_routes": [
    "verification record in local state"
  ],
  "cooldown": "60s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-packet",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-work-packet"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-artifact",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-task-artifact"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "verify-evidence",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-evidence-records"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "verify-work"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "work_packet_complete",
    "verification_criteria_defined"
  ],
  "exit_conditions": [
    "work_verified_or_rejected",
    "verify_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
