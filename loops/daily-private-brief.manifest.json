{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "daily-private-brief-v1",
  "title": "Daily Private Brief",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "daily at 06:00",
  "inputs": [
    "current date",
    "operator state",
    "memory snapshot",
    "budget status"
  ],
  "context_sources": [
    "local state",
    "episodic memory",
    "budget records"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "budget.read",
    "memory.read",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "state readable",
    "memory accessible",
    "budget within limits",
    "brief artifact writable"
  ],
  "evidence_outputs": [
    "brief-date",
    "memory-entries-read",
    "budget-status-snapshot"
  ],
  "receipt_outputs": [
    "daily brief receipt"
  ],
  "knowledge_state_outputs": [
    "daily brief artifact written"
  ],
  "execution_trace_outputs": [
    "daily brief execution trace"
  ],
  "memory_routes": [
    "brief artifact stored locally",
    "receipt logged"
  ],
  "cooldown": "86400s",
  "failure_modes": [
    "memory unavailable",
    "budget exceeded",
    "state unreadable",
    "artifact write failure",
    "timeout"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-state",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-runtime-state"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "daily-brief"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-budget",
      "handler": "budget.read",
      "permission": "budget.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-brief",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {
        "artifactType": "daily-brief"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "daily-brief"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "schedule:daily_06:00",
    "state_readable"
  ],
  "exit_conditions": [
    "brief_artifact_written",
    "receipt_logged"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
