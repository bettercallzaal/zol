{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "ground-before-acting-v1",
  "title": "Ground Before Acting",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "read_only",
  "trigger": "before any outbound action (post, task, relationship change)",
  "inputs": [
    "proposed action (description)",
    "target entity (FID, topic, etc.)",
    "action type (post, capture, relationship)"
  ],
  "context_sources": [
    "operator intention (from memory or explicit input)",
    "recent state snapshots",
    "relationship history with target",
    "ZOL's stated principles (identity)"
  ],
  "allowed_actions": [
    "memory.read",
    "receipt.local.write",
    "relationship.read",
    "source.public.read",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "farcaster.autoupload",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "action intention clear",
    "target entity identifiable",
    "no contradictions with recent memory",
    "relationship state available"
  ],
  "evidence_outputs": [
    "grounding-check timestamp",
    "action verified or flagged",
    "concern(s) identified (if any)"
  ],
  "receipt_outputs": [
    "ground-before-acting receipt"
  ],
  "knowledge_state_outputs": [
    "action grounded in context",
    "assumptions made explicit"
  ],
  "execution_trace_outputs": [
    "ground-before-acting execution trace"
  ],
  "memory_routes": [
    "episodic: action justification",
    "durable: principles adherence log"
  ],
  "cooldown": "per-action (no cooldown, always runs first)",
  "failure_modes": [
    "context unavailable",
    "relationship data stale",
    "memory query failed"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 5,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "read-recent-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "maxRecent": 5
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "check-relationship",
      "handler": "relationship.read",
      "permission": "relationship.read",
      "with": {
        "full": true
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "read-state",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-grounding-state"
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "verify-principles",
      "handler": "source.public.read",
      "permission": "source.public.read",
      "with": {
        "source": "zol-identity-profile"
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "record-grounding-check",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "ground-before-acting"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "action_intent_detected",
    "context_verifiable"
  ],
  "exit_conditions": [
    "context_grounded",
    "grounding_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
