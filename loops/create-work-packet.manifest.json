{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "create-work-packet-v1",
  "title": "Create Work Packet",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "after work intent confirmed",
  "inputs": [
    "confirmed message",
    "memory context",
    "operator confirmation"
  ],
  "context_sources": [
    "inbox",
    "memory",
    "local state"
  ],
  "allowed_actions": [
    "approval.request",
    "memory.read",
    "message.classify",
    "receipt.local.write",
    "state.local.read",
    "state.local.write",
    "task.capture"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "message classifiable",
    "memory accessible",
    "state writable",
    "approval safe to request"
  ],
  "evidence_outputs": [
    "message-classified",
    "context-loaded",
    "work-packet-id",
    "approval-request-sent"
  ],
  "receipt_outputs": [
    "create-work-packet receipt"
  ],
  "knowledge_state_outputs": [
    "work packet written to state",
    "task captured"
  ],
  "execution_trace_outputs": [
    "create-work-packet execution trace"
  ],
  "memory_routes": [
    "work packet in local state"
  ],
  "cooldown": "60s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "classify-message",
      "handler": "message.classify",
      "permission": "message.classify",
      "with": {
        "classificationTarget": "work-type"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-context",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "work-context"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "create-packet",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-work-packet"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "request-approval",
      "handler": "approval.request",
      "permission": "approval.request",
      "with": {
        "approvalType": "work-packet-create"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "create-work-packet"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
