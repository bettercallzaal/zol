{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "close-work-v1",
  "title": "Close Work",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "after verify-work passes",
  "inputs": [
    "work packet",
    "verification evidence"
  ],
  "context_sources": [
    "local state"
  ],
  "allowed_actions": [
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "work packet readable",
    "verification evidence readable",
    "close state writable"
  ],
  "evidence_outputs": [
    "work-packet-id",
    "close-timestamp",
    "evidence-confirmed"
  ],
  "receipt_outputs": [
    "close-work receipt"
  ],
  "knowledge_state_outputs": [
    "work packet closed in state"
  ],
  "execution_trace_outputs": [
    "close-work execution trace"
  ],
  "memory_routes": [
    "closed packet record in local state"
  ],
  "cooldown": "60s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-packet",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-work-packet"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "verify-evidence",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-evidence-records"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "close-packet",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-work-packet-closed"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "close-work"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
