{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "health-check-v1",
  "title": "Health Check",
  "version": "1.0.0",
  "status": "active",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "on startup, after restart, and every 4 hours",
  "cooldown": "14400s",
  "allowed_actions": [
    "budget.read",
    "receipt.local.write",
    "runtime.health.read",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-17",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "check-budget",
      "handler": "budget.read",
      "permission": "budget.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-state",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "check-tools",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-health",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "production-ready",
  "entry_conditions": [
    "scheduler_tick"
  ],
  "exit_conditions": [
    "all_units_checked",
    "health_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 2,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ],
  "inputs": [
    "last_heartbeat_receipt"
  ],
  "context_sources": [
    "local state store",
    "capsule registry health",
    "last heartbeat receipt",
    "SQLite WAL integrity"
  ],
  "checks": [
    "state_store_readable",
    "capsule_registry_valid",
    "last_heartbeat_within_threshold",
    "no_failed_receipts_pending"
  ],
  "evidence_outputs": [
    "health_report"
  ],
  "receipt_outputs": [
    "health-check-receipt"
  ],
  "knowledge_state_outputs": [],
  "execution_trace_outputs": [],
  "memory_routes": []
}
