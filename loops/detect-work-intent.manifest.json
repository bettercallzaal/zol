{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "detect-work-intent-v1",
  "title": "Detect Work Intent",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "on new message or mention",
  "inputs": [
    "incoming message",
    "message metadata"
  ],
  "context_sources": [
    "inbox",
    "local state"
  ],
  "allowed_actions": [
    "inbox.read",
    "message.classify",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "inbox readable",
    "classification handler available",
    "state writable"
  ],
  "evidence_outputs": [
    "message-id",
    "intent-classification",
    "confidence-score"
  ],
  "receipt_outputs": [
    "detect-work-intent receipt"
  ],
  "knowledge_state_outputs": [
    "intent classification written to state"
  ],
  "execution_trace_outputs": [
    "detect-work-intent execution trace"
  ],
  "memory_routes": [
    "intent classification in local state"
  ],
  "cooldown": "60s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-message",
      "handler": "inbox.read",
      "permission": "inbox.read",
      "with": {
        "scope": "latest"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "classify-intent",
      "handler": "message.classify",
      "permission": "message.classify",
      "with": {
        "classificationTarget": "work-intent"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-classification",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-work-intent-classification"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "detect-work-intent"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "operator_input_received",
    "context_loaded"
  ],
  "exit_conditions": [
    "intent_classified",
    "intent_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
