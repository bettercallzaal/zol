{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "source-citation-v1",
  "title": "Source Citation",
  "version": "1.0.0",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "when a claim, research finding, or knowledge product entry requires a source citation",
  "cooldown": "60s",
  "description": "Find, validate, and record a source citation for a knowledge claim. Sources must be approved Zocuments.",
  "allowed_actions": [
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-claim",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "search-sources",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "validate-source",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-citation",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "citation_request_received",
    "approved_sources_accessible"
  ],
  "exit_conditions": [
    "citation_validated_and_recorded",
    "citation_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
