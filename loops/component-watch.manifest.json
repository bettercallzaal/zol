{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "component-watch-v1",
  "title": "Component Watch",
  "version": "1.0.0",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "weekly or after gap analysis produces new candidates",
  "cooldown": "604800s",
  "description": "Monitor external components and tools for new versions, security patches, or capability improvements. Report findings without installing.",
  "allowed_actions": [
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "load-watch-list",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "scan-components",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "detect-updates",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "flag-security",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-watch",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "schedule:periodic",
    "component_sources_accessible"
  ],
  "exit_conditions": [
    "watch_report_written OR no_updates_found",
    "watch_receipt_logged"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
