{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "proof-drop-export-v1",
  "title": "Proof Drop Export",
  "version": "1.0.0",
  "status": "draft",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "operator request to export evidence bundle",
  "inputs": [
    "receipt store reference",
    "bundle scope (time range or session)",
    "sanitization rules"
  ],
  "context_sources": [
    "receipt and evidence store",
    "sanitization config",
    "prior export manifests"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "receipts readable within scope",
    "sanitization rules applied before bundle write",
    "no secrets or private keys in bundle",
    "bundle artifact written successfully"
  ],
  "evidence_outputs": [
    "sanitized evidence bundle artifact",
    "bundle manifest",
    "export timestamp"
  ],
  "receipt_outputs": [
    "proof-drop-export receipt"
  ],
  "knowledge_state_outputs": [
    "evidence bundle exported",
    "export logged in state"
  ],
  "execution_trace_outputs": [
    "proof-drop-export execution trace"
  ],
  "memory_routes": [
    "episodic: export events",
    "durable: exported bundle index"
  ],
  "cooldown": "300s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-receipts",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "receipt-store",
        "scope": "export-bundle"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "sanitize-bundle",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "sanitization-rules",
        "applyTo": "export-bundle"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-bundle",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {
        "artifactType": "proof-drop-bundle",
        "draftOnly": false
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "proof-drop-export"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "specification-only",
  "entry_conditions": [
    "proof_artifact_ready",
    "export_target_defined"
  ],
  "exit_conditions": [
    "proof_exported",
    "export_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
