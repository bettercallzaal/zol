{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "curator-brief-v1",
  "title": "Curator Brief",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "weekly curation cycle or operator request",
  "inputs": [
    "music memory state",
    "current budget snapshot",
    "operator request context"
  ],
  "context_sources": [
    "music memory store",
    "budget ledger",
    "prior curator briefs (state)"
  ],
  "allowed_actions": [
    "approval.request",
    "artifact.local.write",
    "budget.read",
    "memory.read",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "music memory readable",
    "budget within limits",
    "brief not duplicate of last cycle",
    "approval obtained before publishing"
  ],
  "evidence_outputs": [
    "brief draft artifact",
    "budget snapshot at time of brief",
    "approval record"
  ],
  "receipt_outputs": [
    "curator-brief receipt"
  ],
  "knowledge_state_outputs": [
    "brief drafted and approved",
    "curation cycle recorded"
  ],
  "execution_trace_outputs": [
    "curator-brief execution trace"
  ],
  "memory_routes": [
    "episodic: brief decisions and approvals",
    "durable: approved briefs archive"
  ],
  "cooldown": "21600s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-music-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "music-curation-memory"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-budget",
      "handler": "budget.read",
      "permission": "budget.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "draft-brief",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {
        "artifactType": "curator-brief",
        "draftOnly": true
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "request-approval",
      "handler": "approval.request",
      "permission": "approval.request",
      "with": {
        "approvalType": "curator-brief-review",
        "requiredApprover": "zaal"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "curator-brief"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
