{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "task-capture-and-plan-v1",
  "title": "Task Capture and Plan",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "new commitment, request, or idea (from inbox or memory)",
  "inputs": [
    "task description",
    "source (mention, event, memory)",
    "priority hint (if any)"
  ],
  "context_sources": [
    "open task list",
    "recent task velocity",
    "ZOL's current load"
  ],
  "allowed_actions": [
    "receipt.local.write",
    "state.local.read",
    "state.local.write",
    "task.capture",
    "task.plan"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "task description non-empty",
    "no duplicate task",
    "task priority inferred"
  ],
  "evidence_outputs": [
    "task-id",
    "task-title",
    "capture-timestamp",
    "planning-status"
  ],
  "receipt_outputs": [
    "task-capture-and-plan receipt"
  ],
  "knowledge_state_outputs": [
    "task captured",
    "task planned (estimated effort, priority)"
  ],
  "execution_trace_outputs": [
    "task-capture-and-plan trace"
  ],
  "memory_routes": [
    "episodic: capture decision log",
    "durable: task priority patterns"
  ],
  "cooldown": "per-capture (no cooldown)",
  "failure_modes": [
    "task description invalid",
    "duplicate detection failed",
    "state write failed"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 90000,
    "max_steps": 4,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "capture-task",
      "handler": "task.capture",
      "permission": "task.capture",
      "with": {
        "description": "${task_description}",
        "source": "${source}"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "plan-task",
      "handler": "task.plan",
      "permission": "task.plan",
      "with": {
        "scope": "newly-captured"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "update-state",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-task-queue"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-capture",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "task-capture-and-plan"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "task_input_received",
    "planning_context_available"
  ],
  "exit_conditions": [
    "task_captured",
    "plan_artifact_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
