{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "music-scout-v1",
  "title": "Music Scout",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "daily or on curation request",
  "inputs": [
    "memory context",
    "budget status",
    "scout findings source"
  ],
  "context_sources": [
    "episodic memory",
    "budget records",
    "local state"
  ],
  "allowed_actions": [
    "budget.read",
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "memory readable",
    "budget within limits",
    "scout findings accessible",
    "memory writable"
  ],
  "evidence_outputs": [
    "memory-context-read",
    "budget-status-snapshot",
    "scout-findings-count",
    "findings-written"
  ],
  "receipt_outputs": [
    "music-scout receipt"
  ],
  "knowledge_state_outputs": [
    "scout findings written to memory"
  ],
  "execution_trace_outputs": [
    "music-scout execution trace"
  ],
  "memory_routes": [
    "scout findings in episodic memory"
  ],
  "cooldown": "21600s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "music-curation"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-budget",
      "handler": "budget.read",
      "permission": "budget.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "scout-findings",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-scout-findings"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-findings",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "memoryType": "music-scout-findings"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "music-scout"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
