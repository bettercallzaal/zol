{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "request-approval-v1",
  "title": "Request Approval",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "before any consequential action that requires human gate",
  "cooldown": "30s",
  "description": "Submit an approval request to the human authority (Telegram). Wait for acknowledgement before proceeding. Never bypass this gate.",
  "allowed_actions": [
    "approval.request",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "prepare-request",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "submit-approval",
      "handler": "approval.request",
      "permission": "approval.request",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "wait-for-gate",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-gate-result",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "approval_required",
    "request_payload_ready"
  ],
  "exit_conditions": [
    "approval_granted OR approval_denied"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 5000
  },
  "escalation_rules": [
    "deny:action",
    "notify:owner",
    "log:error"
  ],
  "inputs": [],
  "context_sources": [],
  "checks": [],
  "evidence_outputs": [],
  "receipt_outputs": [],
  "knowledge_state_outputs": [],
  "execution_trace_outputs": [],
  "memory_routes": []
}
