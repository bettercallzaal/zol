{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "mastery-receipt-v1",
  "title": "Mastery Receipt",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "after field-test passes required criteria",
  "inputs": [
    "field test evidence artifact",
    "mastery criteria definition",
    "ToolGym session reference"
  ],
  "context_sources": [
    "field test evidence store",
    "mastery criteria config",
    "ToolGym mastery record store"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "receipt.local.write",
    "state.local.read",
    "toolgym.mastery.record"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "field test passed required criteria",
    "mastery not already recorded for this tool/session",
    "mastery record written successfully",
    "receipt issued"
  ],
  "evidence_outputs": [
    "mastery record entry",
    "mastery receipt artifact",
    "mastery timestamp"
  ],
  "receipt_outputs": [
    "mastery-receipt receipt"
  ],
  "knowledge_state_outputs": [
    "tool mastery recorded in ToolGym",
    "mastery receipt issued"
  ],
  "execution_trace_outputs": [
    "mastery-receipt execution trace"
  ],
  "memory_routes": [
    "durable: tool mastery ledger",
    "episodic: mastery milestone events"
  ],
  "cooldown": "86400s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-evidence",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "field-test-evidence",
        "requireStatus": "passed"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-mastery",
      "handler": "toolgym.mastery.record",
      "permission": "toolgym.mastery.record",
      "with": {
        "masterySource": "field-test",
        "evidenceKey": "field-test-evidence"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "mastery-milestone"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "mastery-receipt"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
