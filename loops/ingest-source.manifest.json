{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "ingest-source-v1",
  "title": "Ingest Source",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "when new source material is provided by operator or discovered",
  "cooldown": "300s",
  "allowed_actions": [
    "inbox.read",
    "memory.write",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-source",
      "handler": "inbox.read",
      "permission": "inbox.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "validate-source",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "store-document",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "weave-initial-memory",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "source_url_or_file_provided",
    "ingest_target_defined"
  ],
  "exit_conditions": [
    "source_ingested",
    "ingest_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ],
  "inputs": [],
  "context_sources": [],
  "checks": [],
  "evidence_outputs": [],
  "receipt_outputs": [],
  "knowledge_state_outputs": [],
  "execution_trace_outputs": [],
  "memory_routes": []
}
