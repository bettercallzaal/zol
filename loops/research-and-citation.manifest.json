{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "research-and-citation-v1",
  "title": "Research and Citation",
  "version": "1.0.0",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "read_only",
  "trigger": "research task or operator request",
  "inputs": [
    "research query or topic",
    "scope (narrow, broad, deep)"
  ],
  "context_sources": [
    "recent memory on topic",
    "previous research outputs",
    "operator guidance"
  ],
  "allowed_actions": [
    "memory.read",
    "receipt.local.write",
    "research.synthesize",
    "source.public.read",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "query non-empty",
    "sources accessible",
    "citations formatted"
  ],
  "evidence_outputs": [
    "research-timestamp",
    "query",
    "source-count",
    "synthesis-method"
  ],
  "receipt_outputs": [
    "research-and-citation receipt"
  ],
  "knowledge_state_outputs": [
    "research completed",
    "citations synthesized"
  ],
  "execution_trace_outputs": [
    "research-and-citation trace"
  ],
  "memory_routes": [
    "durable: research findings + citations"
  ],
  "cooldown": "per-research (no cooldown)",
  "failure_modes": [
    "sources unavailable",
    "synthesis timeout",
    "memory read failed"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 180000,
    "max_steps": 4,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-prior-research",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "research-history"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-sources",
      "handler": "source.public.read",
      "permission": "source.public.read",
      "with": {
        "query": "${research_query}",
        "scope": "${research_scope}"
      },
      "retry": {
        "max_attempts": 3
      }
    },
    {
      "id": "synthesize-research",
      "handler": "research.synthesize",
      "permission": "research.synthesize",
      "with": {
        "citationFormat": "structured"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-research",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "research-and-citation"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "research_request_received",
    "knowledge_sources_accessible"
  ],
  "exit_conditions": [
    "research_artifact_written",
    "citations_validated"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
