{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "recovery-and-rollback-v1",
  "title": "Recovery and Rollback",
  "version": "1.0.0",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "failed heartbeat, corrupt state, or operator request",
  "inputs": [
    "failure reason (string)",
    "rollback depth (last checkpoint or age)"
  ],
  "context_sources": [
    "current runtime state",
    "available checkpoints",
    "error logs from receipts"
  ],
  "allowed_actions": [
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "checkpoint available",
    "rollback integrity",
    "no data loss guarantees (notify operator)"
  ],
  "evidence_outputs": [
    "recovery-timestamp",
    "failure-reason",
    "checkpoint-restored-id"
  ],
  "receipt_outputs": [
    "recovery-and-rollback receipt"
  ],
  "knowledge_state_outputs": [
    "state restored from checkpoint",
    "recovery status recorded"
  ],
  "execution_trace_outputs": [
    "recovery-and-rollback trace"
  ],
  "memory_routes": [
    "episodic: recovery event"
  ],
  "cooldown": "no cooldown (emergency)",
  "failure_modes": [
    "no checkpoint available",
    "state corruption unrecoverable",
    "rollback failed"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 3,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "locate-checkpoint",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "listCheckpoints": true
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "restore-state",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "operation": "restore-from-checkpoint"
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "record-recovery",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "recovery-and-rollback"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "production-ready",
  "entry_conditions": [
    "failure_detected",
    "rollback_candidate_exists"
  ],
  "exit_conditions": [
    "rollback_complete_or_skipped",
    "recovery_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 2,
    "backoff_ms": 2000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
