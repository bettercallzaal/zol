{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "project-continuity-resume-v1",
  "title": "Project Continuity Resume",
  "version": "1.0.0",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "session start or operator request",
  "inputs": [
    "previous session ID or project key",
    "requested context depth"
  ],
  "context_sources": [
    "last checkpoint from state-adapter",
    "project durable memories",
    "task status summary",
    "receipts from last session"
  ],
  "allowed_actions": [
    "memory.read",
    "receipt.local.write",
    "state.local.read",
    "task.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "checkpoint integrity",
    "project key valid",
    "no stale data > 7 days old"
  ],
  "evidence_outputs": [
    "resume timestamp",
    "project-key",
    "context-restored: yes/no",
    "gaps-identified"
  ],
  "receipt_outputs": [
    "project-continuity-resume receipt"
  ],
  "knowledge_state_outputs": [
    "session context restored",
    "unfinished tasks re-queued",
    "continuity confirmed"
  ],
  "execution_trace_outputs": [
    "project-continuity-resume trace"
  ],
  "memory_routes": [
    "episodic: session boundary marker",
    "durable: project milestone tracking"
  ],
  "cooldown": "per-session (no cooldown)",
  "failure_modes": [
    "checkpoint missing",
    "context stale or corrupted",
    "state-adapter unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 5,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "load-checkpoint",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-checkpoint-latest"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-project-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "project-durable"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-open-tasks",
      "handler": "task.read",
      "permission": "task.read",
      "with": {
        "filter": "open-or-blocked"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "validate-continuity",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-continuity-state"
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "record-resume",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "project-continuity-resume"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "production-ready",
  "entry_conditions": [
    "agent_restart_detected",
    "active_project_state_exists"
  ],
  "exit_conditions": [
    "project_context_restored",
    "work_resumed"
  ],
  "retry_limits": {
    "max_retries": 2,
    "backoff_ms": 2000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
