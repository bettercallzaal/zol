{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "curiosity-scan-v1",
  "title": "Curiosity Scan",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "weekly background scan for interesting signals",
  "inputs": [
    "current memory context",
    "scan source list",
    "prior scan findings (for dedup)"
  ],
  "context_sources": [
    "memory store",
    "signal source index",
    "prior findings archive"
  ],
  "allowed_actions": [
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "memory readable before scan",
    "scan sources accessible",
    "findings not duplicate of prior scans",
    "memory written successfully with new findings"
  ],
  "evidence_outputs": [
    "new signals found",
    "scan source coverage",
    "findings delta vs last scan"
  ],
  "receipt_outputs": [
    "curiosity-scan receipt"
  ],
  "knowledge_state_outputs": [
    "new findings written to memory",
    "scan cycle recorded"
  ],
  "execution_trace_outputs": [
    "curiosity-scan execution trace"
  ],
  "memory_routes": [
    "episodic: scan session events",
    "durable: interesting signals archive"
  ],
  "cooldown": "604800s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-23",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "curiosity-context"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "scan-sources",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "curiosity-scan-sources"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-findings",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "scope": "curiosity-findings",
        "dedup": true
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "curiosity-scan"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "schedule:periodic",
    "scan_sources_accessible"
  ],
  "exit_conditions": [
    "curiosity_findings_written OR no_findings",
    "scan_receipt_logged"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ],
  "scan_results_cycle1": {
    "cycle": 1,
    "date": "2026-07-23",
    "scan_sources_covered": [
      "zol-internal:test-health",
      "zol-internal:npm-audit",
      "zol-internal:handler-coverage",
      "zol-internal:pr-state",
      "board:engineering-tasks",
      "board:social-stream",
      "component-watch:all-4-targets"
    ],
    "findings": [
      {
        "id": "health-nominal",
        "category": "zol-internal",
        "signal": "ZOL test suite: 554/554 pass (77 suites), 0 npm vulnerabilities, 0 PR review comments across 38 open PRs",
        "assessment": "GREEN — no action required",
        "actionable": false
      },
      {
        "id": "handler-coverage-complete",
        "category": "zol-internal",
        "signal": "72/72 loop handlers wired; 2 permanent stubs remain: farcaster.dm-send (security invariant) and bonfire.delve-recall (upstream dream-net PRs #1559/#1560)",
        "assessment": "Expected — permanent stubs are documented and accepted; no new gaps found",
        "actionable": false
      },
      {
        "id": "board-engineering-clear",
        "category": "board",
        "signal": "0 open engineering board tasks; 50 total open tasks all outside ZOL code scope (social-stream 1087-1093 are Zaal-direct account management tasks)",
        "assessment": "CONFIRMED PARKED — build correctly gates on Zaal merge train",
        "actionable": false
      },
      {
        "id": "component-watch-no-trigger",
        "category": "ecosystem",
        "signal": "Component-watch cycle 2 ran 2026-07-23: Clanker still v4.2.18, Fractally no directory, Optimism S9 concluded 2026-07-11, ZABAL no public API. All 4 targets NOT triggered.",
        "assessment": "No ecosystem changes require ZOL code updates; next component-watch cycle 3 due ~2026-07-30",
        "actionable": false
      },
      {
        "id": "node-runtime",
        "category": "zol-internal",
        "signal": "ZOL running Node.js v20.20.2 locally; CI uses Node 22 LTS (ws/v2-ci yml). Pi will run Node 20 or 22 per runbook.",
        "assessment": "No version conflict. CI gate on Node 22 is correct for LTS compatibility.",
        "actionable": false
      }
    ],
    "new_signals_count": 0,
    "triggered_improvement_proposals": [],
    "scan_receipt": {
      "receipt_type": "curiosity-scan",
      "cycle": 1,
      "status": "complete",
      "outcome": "no_new_signals",
      "next_scan_due": "2026-07-30"
    }
  }
}
