{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "evening-review-v1",
  "title": "Evening Review",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "daily at 9pm or end-of-day operator request",
  "inputs": [
    "current date",
    "review depth (summary or detailed)"
  ],
  "context_sources": [
    "all receipts from today",
    "task completion log",
    "daily memory summary",
    "budget burned today"
  ],
  "allowed_actions": [
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "state.local.read",
    "state.local.write",
    "task.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "receipts available",
    "task log complete",
    "memory writeable"
  ],
  "evidence_outputs": [
    "review-timestamp",
    "tasks-completed-count",
    "errors-encountered-count",
    "daily-summary"
  ],
  "receipt_outputs": [
    "evening-review receipt"
  ],
  "knowledge_state_outputs": [
    "daily summary captured",
    "lessons logged",
    "checkpoint created"
  ],
  "execution_trace_outputs": [
    "evening-review trace"
  ],
  "memory_routes": [
    "episodic: daily review entry",
    "durable: patterns and learnings"
  ],
  "cooldown": "86400s (daily)",
  "failure_modes": [
    "no receipts found (clean day)",
    "memory write failed",
    "checkpoint creation failed"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 180000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-daily-receipts",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-daily-receipt-summary"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-task-log",
      "handler": "task.read",
      "permission": "task.read",
      "with": {
        "filter": "completed-today"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "today"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "synthesize-review",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "memoryType": "daily-review"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "create-checkpoint",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-end-of-day-checkpoint",
        "markCheckpoint": true
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-review",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "evening-review"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ]
}
