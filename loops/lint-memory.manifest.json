{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "lint-memory-v1",
  "title": "Lint Memory",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "daily or operator request",
  "inputs": [
    "full memory store",
    "provenance records",
    "local state"
  ],
  "context_sources": [
    "all memory entries",
    "provenance metadata",
    "local state"
  ],
  "allowed_actions": [
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "memory readable",
    "provenance accessible",
    "issue flags writable"
  ],
  "evidence_outputs": [
    "memory-entries-linted",
    "issues-flagged",
    "provenance-records-checked"
  ],
  "receipt_outputs": [
    "lint-memory receipt"
  ],
  "knowledge_state_outputs": [
    "memory issue flags written"
  ],
  "execution_trace_outputs": [
    "lint-memory execution trace"
  ],
  "memory_routes": [
    "lint issue flags in memory store"
  ],
  "cooldown": "86400s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-all-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "full"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "validate-provenance",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-provenance-records"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "flag-issues",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "memoryType": "lint-flags"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "lint-memory"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
