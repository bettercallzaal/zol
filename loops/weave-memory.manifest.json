{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "weave-memory-v1",
  "title": "Weave Memory",
  "version": "1.0.0",
  "owner": "zolbot",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "after ingest-source or operator request",
  "inputs": [
    "ingested source data",
    "current memory state",
    "operator request context"
  ],
  "context_sources": [
    "local state",
    "working memory",
    "episodic memory"
  ],
  "allowed_actions": [
    "memory.consolidate",
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "state.local.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "source data readable",
    "memory writable",
    "consolidation safe"
  ],
  "evidence_outputs": [
    "source-entries-read",
    "memory-entries-written",
    "consolidation-result"
  ],
  "receipt_outputs": [
    "weave-memory receipt"
  ],
  "knowledge_state_outputs": [
    "working memory updated",
    "episodic memory updated",
    "memory consolidated"
  ],
  "execution_trace_outputs": [
    "weave-memory execution trace"
  ],
  "memory_routes": [
    "working memory store",
    "episodic memory store"
  ],
  "cooldown": "600s",
  "failure_modes": [
    "budget exceeded",
    "timeout",
    "state corruption",
    "handler error"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 60000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-source",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "zol-ingest-source"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-working",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "memoryType": "working"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-episodic",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "memoryType": "episodic"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "consolidate",
      "handler": "memory.consolidate",
      "permission": "memory.consolidate",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "weave-memory"
      },
      "retry": {
        "max_attempts": 2
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "weave_trigger_received",
    "memory_sources_accessible"
  ],
  "exit_conditions": [
    "memory_woven",
    "weave_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
