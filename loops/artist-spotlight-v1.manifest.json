{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "artist-spotlight-v1",
  "title": "Artist Spotlight",
  "version": "1.0.0",
  "owner": "zol-artist-spotlight-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "scheduled weekly on-demand",
  "inputs": [
    "spotlight history from state (artist names + spotlighted dates)",
    "recent favorable artist mentions from Bonfire recall",
    "cooldown window (60 days default)"
  ],
  "context_sources": [
    "spotlight history state key: artist-spotlight-v1-history",
    "bonfire recall (zol-daily.js recall queries for artist context)",
    "recent casts (~/zol/recent-casts.json - artist mentions ZOL has made)"
  ],
  "allowed_actions": [
    "bonfire.delve-recall",
    "state.local.read",
    "state.local.write",
    "farcaster.cast-compose-draft"
  ],
  "blocked_actions": [
    "farcaster.cast-publish",
    "farcaster.autoupload",
    "fund.transfer",
    "public.publish.without_approval",
    "secret.value.read",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "spotlight history integrity",
    "candidate artist filtering (no repeats within 60 days)",
    "draft text quality and length validation",
    "no auto-posting (draft-only enforcement)"
  ],
  "evidence_outputs": [
    "selected artist name",
    "spotlighted-date timestamp",
    "draft cast text"
  ],
  "receipt_outputs": [
    "artist-spotlight receipt"
  ],
  "knowledge_state_outputs": [
    "artist added to spotlight history",
    "spotlight draft composed and staged"
  ],
  "execution_trace_outputs": [
    "artist-spotlight execution trace"
  ],
  "memory_routes": [
    "durable: artist spotlight history (rotation state)"
  ],
  "cooldown": "weekly (7 days) or on-demand",
  "failure_modes": [
    "bonfire recall fetch failed",
    "no eligible artists (all recent artists within cooldown)",
    "draft composition failed",
    "state write failed"
  ],
  "promotion_path": "draft -> active_local -> live_guarded",
  "last_reviewed": "2026-07-16",
  "limits": {
    "max_wall_time_ms": 45000,
    "max_steps": 10,
    "max_retries_per_step": 2
  },
  "approval_gates": {
    "draft_only": {
      "description": "All spotlights are drafts, staged for Zaal approval",
      "approval_required": true
    }
  },
  "steps": [
    {
      "id": "read-spotlight-history",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {
        "stateKey": "artist-spotlight-v1-history"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "fetch-artist-context",
      "handler": "bonfire.delve-recall",
      "permission": "bonfire.delve-recall",
      "with": {
        "query": "ZAO artists collaborations and community members to spotlight",
        "maxEpisodes": 15
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "parse-recent-mentions",
      "handler": "farcaster.recent-casts-parse",
      "permission": "state.local.read",
      "with": {
        "recentPath": "~/zol/recent-casts.json",
        "extractArtists": true
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "filter-candidates",
      "handler": "artist-spotlight.filter-eligible-artists",
      "permission": "state.local.read",
      "with": {
        "cooldownDays": 60,
        "historyState": "artist-spotlight-v1-history"
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "select-artist",
      "handler": "artist-spotlight.select-one-artist",
      "permission": "state.local.read",
      "with": {
        "weightRandom": true
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "compose-draft",
      "handler": "artist-spotlight.compose-spotlight-draft",
      "permission": "farcaster.cast-compose-draft",
      "with": {
        "maxLength": 280,
        "draftOnly": true
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "stage-draft",
      "handler": "artist-spotlight.stage-draft-for-approval",
      "permission": "state.local.write",
      "with": {
        "draftsDirectory": "~/zol/drafts",
        "draftKind": "artist-spotlight"
      },
      "retry": {
        "max_attempts": 1
      }
    },
    {
      "id": "append-to-history",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "artist-spotlight-v1-history",
        "appendMode": true
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-completion",
      "handler": "artist-spotlight.record-spotlight-completion",
      "permission": "state.local.write",
      "with": {
        "eventType": "artist-spotlight-drafted"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "experimental",
  "entry_conditions": [
    "schedule:weekly",
    "artist_roster_available"
  ],
  "exit_conditions": [
    "spotlight_cast_published OR queued",
    "spotlight_receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
