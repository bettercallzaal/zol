{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "memory-consolidation-and-forgetting-v1",
  "title": "Memory Consolidation and Forgetting",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "zol-curator-v1",
  "stewards": [
    "zaal"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "daily or after major session (consolidate episodic -> durable, age out old data)",
  "inputs": [
    "max age for episodic memory (days)",
    "consolidation strategy"
  ],
  "context_sources": [
    "full memory state",
    "receipts from last 24h",
    "task completion logs"
  ],
  "allowed_actions": [
    "memory.read",
    "memory.write",
    "receipt.local.write",
    "state.local.read",
    "state.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "deployment.production.write",
    "fund.transfer",
    "package.install",
    "public.publish.without_approval",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "memory integrity",
    "age calculation correct",
    "no loss of durable facts"
  ],
  "evidence_outputs": [
    "consolidation-timestamp",
    "episodic-count-before",
    "episodic-count-after",
    "promoted-to-durable-count"
  ],
  "receipt_outputs": [
    "memory-consolidation-and-forgetting receipt"
  ],
  "knowledge_state_outputs": [
    "episodic memory consolidated",
    "old data archived/deleted",
    "durable facts updated"
  ],
  "execution_trace_outputs": [
    "memory-consolidation-and-forgetting trace"
  ],
  "memory_routes": [
    "episodic -> durable transition",
    "archive old episodic entries"
  ],
  "cooldown": "86400s (daily)",
  "failure_modes": [
    "memory read failed",
    "consolidation logic error",
    "durable write failed"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 180000,
    "max_steps": 5,
    "max_retries_per_step": 2
  },
  "steps": [
    {
      "id": "read-all-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {
        "scope": "all"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "consolidate-episodic",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "consolidation": "episodic-to-durable",
        "ageThresholdDays": 7
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "delete-old-episodic",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {
        "operation": "delete-aged",
        "ageThresholdDays": 30
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "update-memory-state",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {
        "stateKey": "zol-memory-index"
      },
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-consolidation",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {
        "receiptType": "memory-consolidation-and-forgetting"
      },
      "retry": {
        "max_attempts": 1
      }
    }
  ],
  "lifecycle_state": "dry-run",
  "entry_conditions": [
    "schedule:periodic",
    "memory_above_threshold"
  ],
  "exit_conditions": [
    "memory_consolidated",
    "stale_entries_pruned",
    "receipt_written"
  ],
  "retry_limits": {
    "max_retries": 3,
    "backoff_ms": 1000
  },
  "escalation_rules": [
    "notify:owner",
    "log:error",
    "halt"
  ]
}
