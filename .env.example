# ZOL env vars - NAMES ONLY, no values. Real values never live in this repo.
#
# ZOL does not load a single .env file. Most secrets are read by zol-lib.js and
# individual scripts from fixed files under ~/.zao/private/ and ~/.openclaw/ on
# the Pi; a few flags are passed inline by cron/tmux at invocation time. Both
# kinds are listed here so every var name the code touches is in one place.

# --- Farcaster identity + signer ---
# FID is ZOL's Farcaster ID (3338501), hardcoded in most scripts; some also
# accept it via env. The signer private key lives ONLY in
# ~/.openclaw/farcaster-credentials.json on the Pi (signerPrivateKey field) -
# never as a raw env var, never in this repo.
FID=

# --- Neynar (hub reads/writes) ---
# Real value lives in ~/.zao/private/neynar.env on the Pi.
NEYNAR_API_KEY=

# --- OpenRouter (LLM drafting, model anthropic/claude-fable-5) ---
# Real value lives in ~/.zao/private/openrouter.key on the Pi (raw key file,
# not KEY=VALUE format).
OPENROUTER_MODEL=

# --- Telegram (operator gate - draft approvals ping Zaal here) ---
# Real values live in ~/.zao/private/tg.env on the Pi.
ZOE_BOT_TOKEN=
ZAAL_TELEGRAM_ID=

# --- ZABAL Bonfire (knowledge-graph context) ---
# Real values live in ~/.zao/private/bonfire.env on the Pi.
BONFIRE_API_KEY=
BONFIRE_ID=

# --- Cowork tracker (scout -> orchestrator bridge) ---
# Real values live in ~/.zao/private/zol-drain.env on the Pi.
COWORK_TRACKER_URL=
COWORK_TRACKER_KEY=

# --- Runtime flags (set inline by cron/tmux, not stored in a file) ---
# Toggle a watcher/drain daemon from dry-run into its live mode.
ZABAL_WATCHER_LIVE=
ZOL_DRAIN_LIVE=
# Force dry-run output even when a daemon would otherwise act.
ZOL_DRY=
# Route a Zaal-quote-cast through the draft/gate flow instead of auto-posting.
ZOL_QUOTECAST_DRAFT=
# Channel URL override for zabal-watch.
ZOL_CHANNEL_URL=
# Wall-clock cap (hours) for the overnight research loop.
MAX_RUNTIME_H=
# Max accounts zol-follow.js will follow per run (default 20 if unset).
FOLLOW_DAILY_CAP=

# --- Signer maintenance only (scripts/rotate.js, src/add-signer.js) ---
# Custody wallet private key for registering/removing a signer on the Farcaster
# Key Registry. Read from ~/zol/.zol-wallet-key on the Pi by rotate.js; only
# read from this env var name if add-signer.js is run standalone. Extremely
# sensitive - controls ZOL's on-chain identity, never in this repo.
PRIVATE_KEY=

# --- ZAO event calendar (Luma ICS feed, no auth) ---
# Override for the ZAO Luma calendar's public ICS URL. Default (baked into
# scripts/zol-calendar.js) is the confirmed live feed for luma.com/zao:
# https://api.lu.ma/ics/get?entity=calendar&id=cal-jPH4al7AMlXzdNN
CALENDAR_ICS_URL=
# How many days out to look for upcoming events (default 7 if unset).
CALENDAR_LOOKAHEAD_DAYS=
