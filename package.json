{
  "name": "zol",
  "version": "1.0.0",
  "description": "ZOL (@zolbot, FID 3338501) - the ZAO's music scout on Farcaster. Runs on a Raspberry Pi, cron-driven, human-gated posting.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "check": "for f in scripts/*.js src/*.js; do node --check \"$f\" || exit 1; done && echo 'all scripts OK'",
    "daily": "node scripts/zol-daily.js",
    "dashboard": "node scripts/dashboard.js",
    "dl:test": "node --test vendor/dreamloops/runtime/tests/*.test.js src/__tests__/*.test.js",
    "dl:validate": "node vendor/dreamloops/cli/src/cli.js validate-all capsules/ loops/",
    "dl:secret-scan": "bash scripts/secret-scan.sh",
    "dl:state-migrate": "node scripts/dl-state-migrate.js",
    "dl:state-restore": "node scripts/dl-state-restore.js",
    "dl:dry-run": "echo 'dry-run: not yet wired (phase 4+)' && exit 0"
  },
  "dependencies": {
    "@farcaster/hub-nodejs": "^0.15.9",
    "ethers": "^6.16.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^10.0.0"
  }
}
