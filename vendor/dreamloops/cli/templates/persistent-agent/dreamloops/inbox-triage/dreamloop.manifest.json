{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "inbox-triage-v1",
  "title": "Inbox Triage",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "new messages or scheduled inbox review",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "authorized inboxes",
    "relationship context",
    "current priorities"
  ],
  "allowed_actions": [
    "inbox.read",
    "message.classify",
    "state.local.write",
    "task.capture"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "inbox-triage evidence"
  ],
  "receipt_outputs": [
    "inbox-triage receipt"
  ],
  "knowledge_state_outputs": [
    "inbox-triage knowledge-state update"
  ],
  "execution_trace_outputs": [
    "inbox-triage bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 6,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "read-inbox",
      "handler": "inbox.read",
      "permission": "inbox.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "classify",
      "handler": "message.classify",
      "permission": "message.classify",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "capture-actions",
      "handler": "task.capture",
      "permission": "task.capture",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "save-triage",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
