{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "communication-draft-and-approval-v1",
  "title": "Communication Draft and Approval",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "communication needed",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "audience",
    "relationship memory",
    "channel rules",
    "operator voice"
  ],
  "allowed_actions": [
    "approval.request",
    "communication.draft",
    "memory.read",
    "receipt.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "communication-draft-and-approval evidence"
  ],
  "receipt_outputs": [
    "communication-draft-and-approval receipt"
  ],
  "knowledge_state_outputs": [
    "communication-draft-and-approval knowledge-state update"
  ],
  "execution_trace_outputs": [
    "communication-draft-and-approval bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 6,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "ground",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "draft",
      "handler": "communication.draft",
      "permission": "communication.draft",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "request-approval",
      "handler": "approval.request",
      "permission": "approval.request",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
