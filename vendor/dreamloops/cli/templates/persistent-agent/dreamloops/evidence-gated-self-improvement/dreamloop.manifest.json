{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "evidence-gated-self-improvement-v1",
  "title": "Evidence-Gated Self-Improvement",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "approved local improvement proposal",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "proposal",
    "sandbox policy",
    "test plan",
    "rollback"
  ],
  "allowed_actions": [
    "experiment.local.run",
    "experiment.result.evaluate",
    "proposal.local.read",
    "proposal.local.write",
    "receipt.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced",
    "no self-installation",
    "no live self-modification",
    "rollback documented"
  ],
  "evidence_outputs": [
    "evidence-gated-self-improvement evidence"
  ],
  "receipt_outputs": [
    "evidence-gated-self-improvement receipt"
  ],
  "knowledge_state_outputs": [
    "evidence-gated-self-improvement knowledge-state update"
  ],
  "execution_trace_outputs": [
    "evidence-gated-self-improvement bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 7,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "read-proposal",
      "handler": "proposal.local.read",
      "permission": "proposal.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "run-sandbox",
      "handler": "experiment.local.run",
      "permission": "experiment.local.run",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "evaluate",
      "handler": "experiment.result.evaluate",
      "permission": "experiment.result.evaluate",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "update-proposal",
      "handler": "proposal.local.write",
      "permission": "proposal.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
