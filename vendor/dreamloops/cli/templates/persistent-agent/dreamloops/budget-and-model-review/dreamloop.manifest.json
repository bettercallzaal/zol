{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "budget-and-model-review-v1",
  "title": "Budget and Model Review",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "daily or threshold-based usage review",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "budget",
    "model usage",
    "task outcomes"
  ],
  "allowed_actions": [
    "budget.read",
    "model.usage.read",
    "proposal.local.write",
    "receipt.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "budget-and-model-review evidence"
  ],
  "receipt_outputs": [
    "budget-and-model-review receipt"
  ],
  "knowledge_state_outputs": [
    "budget-and-model-review knowledge-state update"
  ],
  "execution_trace_outputs": [
    "budget-and-model-review bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 6,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "read-budget",
      "handler": "budget.read",
      "permission": "budget.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-usage",
      "handler": "model.usage.read",
      "permission": "model.usage.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "propose",
      "handler": "proposal.local.write",
      "permission": "proposal.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
