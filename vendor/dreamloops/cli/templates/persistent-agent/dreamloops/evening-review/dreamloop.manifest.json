{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "evening-review-v1",
  "title": "Evening Review",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "end of operator day",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "completed tasks",
    "open work",
    "important interactions",
    "new knowledge"
  ],
  "allowed_actions": [
    "checkpoint.local.write",
    "memory.write",
    "receipt.local.write",
    "task.plan",
    "task.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "evening-review evidence"
  ],
  "receipt_outputs": [
    "evening-review receipt"
  ],
  "knowledge_state_outputs": [
    "evening-review knowledge-state update"
  ],
  "execution_trace_outputs": [
    "evening-review bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 7,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "read-tasks",
      "handler": "task.read",
      "permission": "task.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-memory",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "checkpoint",
      "handler": "checkpoint.local.write",
      "permission": "checkpoint.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "plan",
      "handler": "task.plan",
      "permission": "task.plan",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
