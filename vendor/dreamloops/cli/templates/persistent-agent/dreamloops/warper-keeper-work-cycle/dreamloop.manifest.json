{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "warper-keeper-work-cycle-v1",
  "title": "Warper Keeper Work Cycle",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "live_guarded_action",
  "trigger": "assignment-bound key and explicit work assignment available",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "gateway capability document",
    "assignment",
    "Trapper context",
    "operator policy"
  ],
  "allowed_actions": [
    "warper.approval.request",
    "warper.artifact.submit",
    "warper.assignment.read",
    "warper.context.append",
    "warper.receipt.read",
    "warper.trapper.close",
    "warper.trapper.open"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced",
    "assignment key remains secret",
    "idempotency keys supplied",
    "proof verified"
  ],
  "evidence_outputs": [
    "warper-keeper-work-cycle evidence"
  ],
  "receipt_outputs": [
    "warper-keeper-work-cycle receipt"
  ],
  "knowledge_state_outputs": [
    "warper-keeper-work-cycle knowledge-state update"
  ],
  "execution_trace_outputs": [
    "warper-keeper-work-cycle bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 9,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "get-assignment",
      "handler": "warper.assignment.read",
      "permission": "warper.assignment.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "open-trapper",
      "handler": "warper.trapper.open",
      "permission": "warper.trapper.open",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "append-context",
      "handler": "warper.context.append",
      "permission": "warper.context.append",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "submit-artifact",
      "handler": "warper.artifact.submit",
      "permission": "warper.artifact.submit",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "request-approval",
      "handler": "warper.approval.request",
      "permission": "warper.approval.request",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "close-trapper",
      "handler": "warper.trapper.close",
      "permission": "warper.trapper.close",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "verify-proof",
      "handler": "warper.receipt.read",
      "permission": "warper.receipt.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
