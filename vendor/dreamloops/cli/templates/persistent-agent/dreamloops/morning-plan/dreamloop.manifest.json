{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "morning-plan-v1",
  "title": "Morning Plan",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "start of operator day",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "calendar",
    "open tasks",
    "deadlines",
    "energy and budget constraints"
  ],
  "allowed_actions": [
    "calendar.read",
    "priority.plan",
    "receipt.local.write",
    "state.local.write",
    "task.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "morning-plan evidence"
  ],
  "receipt_outputs": [
    "morning-plan receipt"
  ],
  "knowledge_state_outputs": [
    "morning-plan knowledge-state update"
  ],
  "execution_trace_outputs": [
    "morning-plan bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 7,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "read-calendar",
      "handler": "calendar.read",
      "permission": "calendar.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-tasks",
      "handler": "task.read",
      "permission": "task.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "plan-priorities",
      "handler": "priority.plan",
      "permission": "priority.plan",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "save-plan",
      "handler": "state.local.write",
      "permission": "state.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
