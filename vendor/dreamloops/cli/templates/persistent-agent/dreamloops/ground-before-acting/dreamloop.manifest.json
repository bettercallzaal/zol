{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "ground-before-acting-v1",
  "title": "Ground Before Acting",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "before a consequential response or task",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "relevant memories",
    "relationship history",
    "project state"
  ],
  "allowed_actions": [
    "memory.read",
    "project.read",
    "receipt.local.write",
    "relationship.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "ground-before-acting evidence"
  ],
  "receipt_outputs": [
    "ground-before-acting receipt"
  ],
  "knowledge_state_outputs": [
    "ground-before-acting knowledge-state update"
  ],
  "execution_trace_outputs": [
    "ground-before-acting bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 6,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "recall",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "load-relationship",
      "handler": "relationship.read",
      "permission": "relationship.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "load-project",
      "handler": "project.read",
      "permission": "project.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-grounding",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
