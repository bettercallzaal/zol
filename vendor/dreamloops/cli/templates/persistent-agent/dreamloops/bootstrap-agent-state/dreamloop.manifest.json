{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "bootstrap-agent-state-v1",
  "title": "Bootstrap Agent State",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "process start or operator request",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "identity profile",
    "latest checkpoint",
    "open tasks",
    "recent memories"
  ],
  "allowed_actions": [
    "memory.read",
    "receipt.local.write",
    "state.local.read",
    "task.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "bootstrap-agent-state evidence"
  ],
  "receipt_outputs": [
    "bootstrap-agent-state receipt"
  ],
  "knowledge_state_outputs": [
    "bootstrap-agent-state knowledge-state update"
  ],
  "execution_trace_outputs": [
    "bootstrap-agent-state bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 6,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "load-state",
      "handler": "state.local.read",
      "permission": "state.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "recall-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "load-tasks",
      "handler": "task.read",
      "permission": "task.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "record-bootstrap",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
