{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "component-radar-v1",
  "title": "Component Radar",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "scheduled ecosystem review or observed limitation",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "current component catalog",
    "public release notes",
    "known gaps"
  ],
  "allowed_actions": [
    "component.catalog.read",
    "proposal.local.write",
    "receipt.local.write",
    "source.public.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "component-radar evidence"
  ],
  "receipt_outputs": [
    "component-radar receipt"
  ],
  "knowledge_state_outputs": [
    "component-radar knowledge-state update"
  ],
  "execution_trace_outputs": [
    "component-radar bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 6,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "scan-public",
      "handler": "source.public.read",
      "permission": "source.public.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-catalog",
      "handler": "component.catalog.read",
      "permission": "component.catalog.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-proposal",
      "handler": "proposal.local.write",
      "permission": "proposal.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
