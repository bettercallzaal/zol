{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "project-continuity-resume-v1",
  "title": "Project Continuity Resume",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "project resumed after interruption or restart",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "project checkpoint",
    "open tasks",
    "latest decisions",
    "known blockers"
  ],
  "allowed_actions": [
    "checkpoint.local.write",
    "project.read",
    "project.write",
    "task.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "project-continuity-resume evidence"
  ],
  "receipt_outputs": [
    "project-continuity-resume receipt"
  ],
  "knowledge_state_outputs": [
    "project-continuity-resume knowledge-state update"
  ],
  "execution_trace_outputs": [
    "project-continuity-resume bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 6,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "read-project",
      "handler": "project.read",
      "permission": "project.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-tasks",
      "handler": "task.read",
      "permission": "task.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "update-project",
      "handler": "project.write",
      "permission": "project.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "save-checkpoint",
      "handler": "checkpoint.local.write",
      "permission": "checkpoint.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
