{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "memory-consolidation-and-forgetting-v1",
  "title": "Memory Consolidation and Forgetting",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "nightly or storage-pressure review",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "episodic memory",
    "retention policy",
    "provenance",
    "sensitivity"
  ],
  "allowed_actions": [
    "memory.consolidate",
    "memory.expire",
    "memory.read",
    "memory.write",
    "receipt.local.write"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "memory-consolidation-and-forgetting evidence"
  ],
  "receipt_outputs": [
    "memory-consolidation-and-forgetting receipt"
  ],
  "knowledge_state_outputs": [
    "memory-consolidation-and-forgetting knowledge-state update"
  ],
  "execution_trace_outputs": [
    "memory-consolidation-and-forgetting bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 7,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "read-memory",
      "handler": "memory.read",
      "permission": "memory.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "consolidate",
      "handler": "memory.consolidate",
      "permission": "memory.consolidate",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "expire",
      "handler": "memory.expire",
      "permission": "memory.expire",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "save",
      "handler": "memory.write",
      "permission": "memory.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "receipt",
      "handler": "receipt.local.write",
      "permission": "receipt.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
