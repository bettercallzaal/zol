{
  "schema": "dreamnet.dreamloop.v1",
  "loop_id": "research-and-citation-v1",
  "title": "Research and Citation",
  "version": "1.0.0",
  "status": "rehearsed",
  "owner": "persistent-agent-base-v1",
  "stewards": [
    "agent_operator"
  ],
  "permission_tier": "local_draft_write",
  "trigger": "question requiring external or local evidence",
  "inputs": [
    "agent identity",
    "current objective",
    "current time",
    "operator policy"
  ],
  "context_sources": [
    "local knowledge",
    "authorized public sources",
    "source quality policy"
  ],
  "allowed_actions": [
    "artifact.local.write",
    "citation.write",
    "research.synthesize",
    "source.local.read",
    "source.public.read"
  ],
  "blocked_actions": [
    "cloud.mutate",
    "component.install",
    "connector.unbounded.write",
    "deployment.production.write",
    "package.install",
    "public.publish",
    "secret.value.read",
    "self.modify.live",
    "signer.change",
    "wallet.sign"
  ],
  "checks": [
    "permissions granted",
    "resource ceilings intact",
    "receipt produced"
  ],
  "evidence_outputs": [
    "research-and-citation evidence"
  ],
  "receipt_outputs": [
    "research-and-citation receipt"
  ],
  "knowledge_state_outputs": [
    "research-and-citation knowledge-state update"
  ],
  "execution_trace_outputs": [
    "research-and-citation bounded execution trace"
  ],
  "memory_routes": [
    "local episodic memory",
    "promote only verified durable facts"
  ],
  "cooldown": "host policy",
  "failure_modes": [
    "permission denied",
    "unregistered handler",
    "timeout",
    "invalid state",
    "dependency unavailable"
  ],
  "promotion_path": "rehearsed -> active_local -> live_guarded",
  "last_reviewed": "2026-07-14",
  "limits": {
    "max_wall_time_ms": 120000,
    "max_steps": 7,
    "max_retries_per_step": 1
  },
  "steps": [
    {
      "id": "read-local",
      "handler": "source.local.read",
      "permission": "source.local.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "read-public",
      "handler": "source.public.read",
      "permission": "source.public.read",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "synthesize",
      "handler": "research.synthesize",
      "permission": "research.synthesize",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "cite",
      "handler": "citation.write",
      "permission": "citation.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    },
    {
      "id": "write-artifact",
      "handler": "artifact.local.write",
      "permission": "artifact.local.write",
      "with": {},
      "retry": {
        "max_attempts": 2
      }
    }
  ]
}
