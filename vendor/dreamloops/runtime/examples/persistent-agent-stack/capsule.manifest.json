{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "persistent-agent-stack-v1",
  "name": "Persistent Agent Stack",
  "version": "1.0.0",
  "capsule_type": "runtime_profile",
  "status": "rehearsed",
  "purpose": "Provide restart-safe local state, bounded memory, health inspection, receipts, and proposal-only component discovery without granting live action authority.",
  "payload": {
    "components": [
      "identity-policy-kernel",
      "sqlite-wal-state",
      "memory-governor",
      "runtime-supervisor",
      "persistent-scheduler",
      "transactional-outbox",
      "model-tool-gateway",
      "receipt-ledger",
      "backup-restore-verifier",
      "component-radar"
    ],
    "dreamloops": ["persistent-agent-heartbeat-v1"]
  },
  "permissions": {
    "allowed": ["artifact.local.write", "runtime.health.read"],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "production.deploy",
      "signer.change",
      "social.publish",
      "wallet.sign"
    ]
  },
  "resource_limits": {
    "max_wall_time_ms": 30000,
    "max_steps": 10,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "content_hash": "sha256:74a4ce66de340650349f65a8872e13538b9fd56e81a758e20baeb5844de2a496"
  }
}
