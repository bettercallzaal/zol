{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "zao-wins-spotter-v1",
  "name": "ZAO Community Wins Spotter",
  "version": "1.0.0",
  "capsule_type": "community_curator",
  "status": "prototype",
  "purpose": "Discover underappreciated wins from the ZAO ecosystem via local receipts and episodes. Detect dominant themes (music focus, builder energy, web3 momentum, community vibes). Draft genuine celebration casts — draft-only, Telegram-gated before any public post.",
  "author": "zolbot",
  "created": "2026-07-17",
  "payload": {
    "components": [
      "win-episode-parser",
      "pattern-detector",
      "celebration-drafter",
      "draft-validator"
    ],
    "data_sources": [
      "local_receipts",
      "local_state",
      "bonfire_optional"
    ],
    "bonfire_note": "bonfire.delve integration deferred until Bonfire access is available. Falls back to local receipt state.",
    "voice_policy": {
      "style": "genuine-joyful",
      "tone": "no emojis, no em dashes, clear and actionable",
      "approach": "celebrate specific people and wins, not generic praise"
    }
  },
  "handlers": [
    "community.wins.spot"
  ],
  "permissions": {
    "allowed": [
      "approval.request",
      "artifact.draft.write",
      "memory.read",
      "memory.write",
      "receipt.local.read",
      "receipt.local.write",
      "state.local.read",
      "state.local.write"
    ],
    "blocked": [
      "cloud.mutate",
      "deployment.production.write",
      "farcaster.post",
      "farcaster.reply",
      "fund.transfer",
      "package.install",
      "public.publish.without_approval",
      "secret.value.read",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "community-wins-spotlight-v1"
    ],
    "disallowed_wallets": [
      "*"
    ],
    "disallowed_signers": [
      "*"
    ]
  },
  "resource_limits": {
    "max_wall_time_ms": 30000,
    "max_steps": 6,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled",
    "flag_gated_off": true,
    "requires_env_check": "ZAO_WINS_SPOTTER_ENABLED"
  },
  "provenance": {
    "source": "https://github.com/bettercallzaal/zol",
    "ported_from": "ws/dreamloops-surprise-wins-spotter (PR #18)",
    "content_hash": "sha256:97663ab04258ab6b471c71da1dd79248b5ff4ad29ff5cfc41967afaf09b96f8e"
  }
}
