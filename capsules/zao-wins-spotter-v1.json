{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "zao-wins-spotter-v1",
  "name": "ZAO Community Wins Spotter",
  "version": "1.0.0",
  "capsule_type": "community_discovery",
  "status": "rehearsed",
  "purpose": "Discover underappreciated community wins from Bonfire shared-graph memory, synthesize genuine celebration casts (draft-only), and build patterns of what energizes the ZAO ecosystem.",
  "payload": {
    "components": [
      "bonfire-query-engine",
      "win-pattern-detector",
      "voice-generator",
      "draft-composer",
      "memory-consolidation"
    ],
    "memory_policy": {
      "provenance_required": true,
      "consolidation": "daily",
      "forgetting": "policy_driven",
      "secret_values": "forbidden"
    },
    "operating_modes": [
      "disabled",
      "dry_run",
      "draft_only"
    ]
  },
  "permissions": {
    "allowed": [
      "bonfire.query",
      "farcaster.read",
      "memory.read",
      "memory.write",
      "receipt.local.write",
      "artifact.draft.write",
      "approval.request"
    ],
    "blocked": [
      "farcaster.post",
      "farcaster.autoupload",
      "fund.transfer",
      "wallet.sign",
      "deployment.production.write",
      "signer.change"
    ]
  },
  "resource_limits": {
    "max_wall_time_ms": 300000,
    "max_steps": 12,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/bettercallzaal/zol",
    "created": "2026-07-14",
    "purpose": "Celebrate ZAO community excellence via shared Bonfire memory"
  }
}
