{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "zol-toolgym-client-v1",
  "name": "ZOL ToolGym Client",
  "version": "1.0.0",
  "capsule_type": "runtime_profile",
  "status": "rehearsed",
  "purpose": "Export training manifests, run bounded tool workouts, attach verification evidence, record mastery receipts.",
  "payload": {
    "components": [
      "workout-runner",
      "mastery-recorder",
      "training-manifest-exporter"
    ]
  },
  "permissions": {
    "allowed": [
      "approval.request",
      "artifact.local.write",
      "budget.read",
      "receipt.local.write",
      "state.local.read",
      "state.local.write",
      "toolgym.mastery.record",
      "toolgym.workout.run"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ]
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:pending"
  }
}
