{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "zol-core-continuity-v1",
  "name": "ZOL Core Continuity",
  "version": "1.0.0",
  "capsule_type": "runtime_profile",
  "status": "rehearsed",
  "purpose": "Durable identity, bootstrap, heartbeat, health-check, restart-recovery, and daily-private-brief for zolbot.",
  "payload": {
    "components": [
      "identity-policy-kernel",
      "durable-local-state",
      "heartbeat-scheduler",
      "restart-recovery",
      "daily-brief-runner"
    ]
  },
  "permissions": {
    "allowed": [
      "approval.request",
      "budget.read",
      "memory.read",
      "memory.write",
      "receipt.local.write",
      "runtime.health.read",
      "state.local.read",
      "state.local.write"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "heartbeat",
      "health-check",
      "restart-recovery",
      "bootstrap-state",
      "daily-private-brief"
    ],
    "allowed_tools": [
      "state.read",
      "state.write",
      "receipt.read",
      "receipt.write"
    ],
    "allowed_data": [
      "state.local",
      "receipt.local",
      "runtime.health"
    ],
    "disallowed_wallets": [
      "*"
    ],
    "disallowed_signers": [
      "*"
    ],
    "disallowed_environments": []
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:91eca9f381dcebef364afccf8c96e741ddcd1b2ab38e36550da117ad85412568"
  }
}
