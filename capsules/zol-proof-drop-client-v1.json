{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "zol-proof-drop-client-v1",
  "name": "ZOL Proof Drop Client",
  "version": "1.0.0",
  "capsule_type": "runtime_profile",
  "status": "rehearsed",
  "purpose": "Export sanitized receipt or evidence bundles without exposing prompts, private memory, credentials, or internal files.",
  "payload": {
    "components": [
      "receipt-sanitizer",
      "evidence-bundler",
      "proof-drop-exporter"
    ]
  },
  "permissions": {
    "allowed": [
      "artifact.local.write",
      "budget.read",
      "receipt.local.write",
      "state.local.read"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "receipt-sanitize",
      "evidence-bundle",
      "proof-drop-export"
    ],
    "allowed_tools": [
      "state.read",
      "receipt.read",
      "artifact.write"
    ],
    "allowed_data": [
      "state.local",
      "receipt.local",
      "artifact.local"
    ],
    "disallowed_wallets": ["*"],
    "disallowed_signers": ["*"],
    "disallowed_environments": ["production"]
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:pending"
  }
}
