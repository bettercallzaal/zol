{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "zol-builder-and-artifact-v1",
  "name": "ZOL Builder and Artifact",
  "version": "1.0.0",
  "capsule_type": "runtime_profile",
  "status": "rehearsed",
  "purpose": "Plan, build, verify, package, version, and deliver documents, research, code, and data artifacts.",
  "payload": {
    "components": [
      "artifact-planner",
      "builder-delegate",
      "artifact-verifier",
      "trapper-packager"
    ]
  },
  "permissions": {
    "allowed": [
      "approval.request",
      "artifact.local.write",
      "budget.read",
      "memory.read",
      "receipt.local.write",
      "state.local.read",
      "state.local.write",
      "task.read"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ]
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:pending"
  }
}
