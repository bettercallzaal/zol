{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "zol-work-router-v1",
  "name": "ZOL Work Router",
  "version": "1.0.0",
  "capsule_type": "runtime_profile",
  "status": "rehearsed",
  "purpose": "Classify conversation vs real work, create work packets, route tasks, resume after restart, close with evidence.",
  "payload": {
    "components": [
      "work-classifier",
      "packet-creator",
      "task-router",
      "checkpoint-manager"
    ]
  },
  "permissions": {
    "allowed": [
      "approval.request",
      "budget.read",
      "memory.read",
      "message.classify",
      "receipt.local.write",
      "state.local.read",
      "state.local.write",
      "task.capture",
      "task.plan",
      "task.read"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ]
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:pending"
  }
}
