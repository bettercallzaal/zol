{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "zol-self-improvement-v1",
  "name": "ZOL Self Improvement",
  "version": "1.0.0",
  "capsule_type": "runtime_profile",
  "status": "rehearsed",
  "purpose": "Detect capability gaps, research improvements, test in isolation, and submit upgrade proposals. Never self-modify without Zaal approval.",
  "payload": {
    "components": [
      "gap-detector",
      "improvement-researcher",
      "sandbox-tester",
      "proposal-submitter"
    ],
    "approval_gate": "zaal-required"
  },
  "permissions": {
    "allowed": [
      "approval.request",
      "artifact.local.write",
      "budget.read",
      "memory.read",
      "receipt.local.write",
      "state.local.read",
      "state.local.write",
      "task.capture",
      "task.read"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "capability-gap-analysis",
      "improvement-proposal",
      "evidence-gated-self-improvement",
      "curiosity-scan"
    ],
    "allowed_tools": [
      "state.read",
      "state.write"
    ],
    "allowed_data": [
      "state.local",
      "artifact.local",
      "receipt.local"
    ],
    "disallowed_wallets": [
      "*"
    ],
    "disallowed_signers": [
      "*"
    ],
    "disallowed_environments": []
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:367f367b18c7987ff747eb7bb76c23e73fda99b52d7485c3facbdad49def0e35"
  }
}
