{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "community-crm-v1",
  "name": "Community CRM - Relationship Lifecycle",
  "version": "1.0.0",
  "capsule_type": "agent_capability",
  "status": "draft",
  "purpose": "Track and nurture community relationships across their lifecycle: discover, engage, coordinate, escalate, and nurture. Integrated with ZAO circles + cowork tracker.",
  "payload": {
    "capability_identity": {
      "name": "community-crm-v1",
      "owner": "zoe-orchestrator",
      "integration_points": [
        "circles (member events, relationship status)",
        "cowork tracker (project contributions)",
        "farcaster (member activity, DM sending)",
        "zao-logs (relationship event history)"
      ],
      "mission": "Surface appropriate relationship actions at each lifecycle stage without sybil or spam behavior",
      "operational_context": "Low-risk, humans-in-the-loop for bulk actions, relationship data is immutable log-based"
    },
    "relationship_stages": {
      "discover": {
        "description": "Recently joined, minimal activity",
        "criteria": "Joined <7 days ago OR <5 casts in community channels",
        "action": "welcome-dm-and-intro-link",
        "auto_send": true
      },
      "engage": {
        "description": "Active participant in community",
        "criteria": ">1 cast/week in community OR viewed >3 projects",
        "action": "invite-to-next-sync-or-workshop",
        "auto_send": false,
        "requires_approval": true
      },
      "coordinate": {
        "description": "Active contributor in a project",
        "criteria": "Active in a ZAO project (cowork board)",
        "action": "surface-related-projects",
        "auto_send": true
      },
      "escalate": {
        "description": "Leadership or high-value contributor",
        "criteria": "Leadership role (mentor, core team, moderator)",
        "action": "flag-for-zaal-strategic-call",
        "auto_send": false,
        "requires_approval": true
      },
      "nurture": {
        "description": "Was active, now inactive",
        "criteria": "Was active, now inactive >30d",
        "action": "gentle-reengagement-dm",
        "auto_send": false,
        "requires_approval": true
      }
    },
    "runtime_profile": {
      "platform": "cloud_or_pi",
      "deployment_model": "event_driven_loop",
      "persist_state": true,
      "budgets": {
        "dms_per_day": 500,
        "relationship_updates_per_day": 100,
        "bulk_send_max_per_batch": 10
      }
    },
    "configuration_references": {
      "event_sources": [
        "circle.relationship-state-change",
        "circle.member-joined",
        "circle.member-activity"
      ],
      "env_vars": [
        "DREAMLOOPS_ENABLED",
        "COMMUNITY_CRM_ENABLED"
      ],
      "note": "Feature flags control loop activation; relationship data is read from circles + cowork, written only to local state"
    }
  },
  "permissions": {
    "allowed": [
      "circle.member-event-stream",
      "circle.relationship-status-read",
      "circle.relationship-status-write",
      "cowork.fetch-projects",
      "farcaster.activity-read",
      "farcaster.dm-send",
      "log.relationship-events-write",
      "message.classify",
      "priority.plan",
      "state.local.read",
      "state.local.write"
    ],
    "blocked": [
      "circle.member-remove",
      "circle.role-grant",
      "farcaster.autoupload",
      "fund.transfer",
      "public.publish.without_approval",
      "secret.value.read",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "relationship-discover",
      "relationship-engage",
      "relationship-coordinate",
      "relationship-escalate",
      "relationship-nurture",
      "inbox-triage"
    ],
    "allowed_tools": [
      "farcaster.read",
      "state.read",
      "state.write"
    ],
    "allowed_data": [
      "state.local",
      "relationship.local",
      "farcaster.public",
      "circle.member"
    ],
    "disallowed_wallets": ["*"],
    "disallowed_signers": ["*"],
    "disallowed_environments": []
  },
  "resource_limits": {
    "max_wall_time_ms": 30000,
    "max_steps": 15,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "flag_gated_off",
    "rollback_version": "disabled",
    "feature_flags": [
      "DREAMLOOPS_ENABLED",
      "COMMUNITY_CRM_ENABLED"
    ]
  },
  "provenance": {
    "source": "https://github.com/bettercallzaal/zol",
    "content_hash": "sha256:draft-community-crm-v1"
  }
}
