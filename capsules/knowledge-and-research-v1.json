{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "knowledge-and-research-v1",
  "name": "Knowledge and Research",
  "version": "1.0.0",
  "capsule_type": "capability_profile",
  "status": "rehearsed",
  "purpose": "Collect, compare, synthesize, and cite local or public information while separating evidence from inference.",
  "payload": {
    "evidence_policy": {
      "citations_required": true,
      "inference_labeled": true,
      "private_sources": "explicit_permission_only"
    }
  },
  "permissions": {
    "allowed": [
      "artifact.local.write",
      "citation.write",
      "research.synthesize",
      "source.local.read",
      "source.public.read"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "connector.unbounded.write",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "research-collect",
      "research-synthesize",
      "research-cite",
      "ingest-source"
    ],
    "allowed_tools": [
      "state.read",
      "artifact.write"
    ],
    "allowed_data": [
      "artifact.local",
      "source.local",
      "source.public"
    ],
    "disallowed_wallets": ["*"],
    "disallowed_signers": ["*"],
    "disallowed_environments": []
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:e04c87a9e9c630aa554d76be91b8eb23e4c9c28230e61181d88bb2e48b8b54c0"
  }
}
