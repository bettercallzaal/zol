{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "zol-warper-keeper-client-v1",
  "name": "ZOL Warper Keeper Client",
  "version": "1.0.0",
  "capsule_type": "runtime_profile",
  "status": "rehearsed",
  "purpose": "Accept Warper assignments, open/sync/release Trappers through the Warper Keeper adapter (disabled/mock/remote).",
  "payload": {
    "components": [
      "warper-assignment-handler",
      "trapper-lifecycle-manager"
    ],
    "warper_keeper_mode": "disabled"
  },
  "permissions": {
    "allowed": [
      "approval.request",
      "artifact.local.write",
      "budget.read",
      "receipt.local.write",
      "state.local.read",
      "state.local.write",
      "warper.assignment.accept",
      "warper.trapper.open",
      "warper.trapper.release",
      "warper.trapper.sync"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "warper-assignment-accept",
      "trapper-open",
      "trapper-sync",
      "trapper-release"
    ],
    "allowed_tools": [
      "state.read",
      "state.write",
      "receipt.write",
      "artifact.write"
    ],
    "allowed_data": [
      "state.local",
      "receipt.local",
      "artifact.local",
      "warper.assignment"
    ],
    "disallowed_wallets": [
      "*"
    ],
    "disallowed_signers": [
      "*"
    ],
    "disallowed_environments": [
      "production"
    ]
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:02371f0e987cf55a212a345742445244959c1a4d33adea8124f88d43e89114de"
  }
}
