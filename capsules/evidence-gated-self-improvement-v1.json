{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "evidence-gated-self-improvement-v1",
  "name": "Evidence-Gated Self-Improvement",
  "version": "1.0.0",
  "capsule_type": "capability_profile",
  "status": "rehearsed",
  "purpose": "Discover useful components and propose bounded improvements without self-installation, live self-modification, or silent promotion.",
  "payload": {
    "lifecycle": [
      "observed",
      "proposed",
      "approved_for_sandbox",
      "tested",
      "reviewed",
      "approved_for_canary",
      "canary",
      "accepted_or_rejected"
    ],
    "automatic_installation": false
  },
  "permissions": {
    "allowed": [
      "component.catalog.read",
      "experiment.local.run",
      "experiment.result.evaluate",
      "proposal.local.read",
      "proposal.local.write",
      "source.public.read"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "connector.unbounded.write",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "capability-gap-analysis",
      "improvement-proposal",
      "evidence-gated-self-improvement",
      "curiosity-scan"
    ],
    "allowed_tools": [
      "state.read",
      "state.write"
    ],
    "allowed_data": [
      "state.local",
      "proposal.local",
      "source.public"
    ],
    "disallowed_wallets": [
      "*"
    ],
    "disallowed_signers": [
      "*"
    ],
    "disallowed_environments": [
      "production"
    ]
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:c1a577d1cdefa6c7d6509a0fabd35857833e6e580add33fdd4b2c094a9e95754"
  }
}
