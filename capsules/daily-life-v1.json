{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "daily-life-v1",
  "name": "Daily Life",
  "version": "1.0.0",
  "capsule_type": "capability_profile",
  "status": "rehearsed",
  "purpose": "Organize ordinary daily work, reminders, inboxes, relationships, projects, and reflective review without autonomous public action.",
  "payload": {
    "preferences": {
      "plan_horizon": "one_day",
      "interruptions": "triaged",
      "reminders": "bounded",
      "review": "evening"
    }
  },
  "permissions": {
    "allowed": [
      "calendar.read",
      "inbox.read",
      "message.classify",
      "priority.plan",
      "project.read",
      "project.write",
      "relationship.read",
      "relationship.write",
      "task.capture",
      "task.plan",
      "task.read"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "connector.unbounded.write",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "daily-plan",
      "inbox-triage",
      "task-capture",
      "evening-review"
    ],
    "allowed_tools": [
      "state.read",
      "state.write"
    ],
    "allowed_data": [
      "state.local",
      "calendar.local",
      "inbox.local",
      "task.local",
      "project.local",
      "relationship.local"
    ],
    "disallowed_wallets": [
      "*"
    ],
    "disallowed_signers": [
      "*"
    ],
    "disallowed_environments": []
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:d17471ab6510b29ae95cc86b49282b01857f9ca69d6777c60a86ec8d7f389d18"
  }
}
