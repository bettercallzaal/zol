{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "sparkz-launch-readiness-v1",
  "name": "Sparkz Launch Readiness Energy Score",
  "version": "1.0.0",
  "capsule_type": "decision_engine",
  "status": "prototype",
  "purpose": "Compute energy score (0-100) from creator Farcaster signals and determine token launch readiness. Outputs recommendation: launch_now, keep_building, or insufficient_data. Read-only on Farcaster data; no posting, no wallet actions.",
  "author": "zolbot",
  "created": "2026-07-17",
  "payload": {
    "components": [
      "farcaster-signal-reader",
      "energy-score-calculator",
      "momentum-tracker",
      "launch-readiness-recommender"
    ],
    "energy_formula": {
      "follower_growth_weight": 0.25,
      "engagement_rate_weight": 0.35,
      "consistency_score_weight": 0.2,
      "community_size_weight": 0.2,
      "minimum_launch_threshold": 60,
      "description": "Energy score weighted average of four signals, normalized 0-100"
    },
    "operating_modes": [
      "disabled",
      "dry_run",
      "local_read",
      "live_guarded"
    ],
    "memory_policy": {
      "provenance_required": true,
      "consolidation": "weekly",
      "forgetting": "policy_driven",
      "secret_values": "forbidden"
    }
  },
  "handlers": [
    "farcaster.follower-growth-read",
    "farcaster.cast-engagement-read",
    "farcaster.channel-activity-read",
    "energy-score.compute",
    "energy-score.launch-recommendation",
    "energy-score.trend-analysis",
    "state.energy-history-write",
    "receipt.launch-recommendation-write"
  ],
  "permissions": {
    "allowed": [
      "approval.request",
      "budget.read",
      "farcaster.follower-growth-read",
      "farcaster.cast-engagement-read",
      "farcaster.channel-activity-read",
      "memory.read",
      "memory.write",
      "receipt.local.write",
      "state.local.read",
      "state.local.write"
    ],
    "blocked": [
      "cloud.mutate",
      "deployment.production.write",
      "farcaster.post",
      "farcaster.post.approval",
      "package.install",
      "public.publish",
      "secret.value.read",
      "signer.change",
      "wallet.sign",
      "wallet.transfer"
    ],
    "allowed_loops": [
      "sparkz-launch-readiness-v1"
    ],
    "disallowed_wallets": [
      "*"
    ],
    "disallowed_signers": [
      "*"
    ]
  },
  "resource_limits": {
    "max_wall_time_ms": 30000,
    "max_steps": 20,
    "max_retries_per_step": 2,
    "max_creators_per_run": 100
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled",
    "flag_gated_off": true,
    "requires_env_check": "SPARKZ_LAUNCH_READINESS_ENABLED"
  },
  "provenance": {
    "source": "https://github.com/bettercallzaal/zol",
    "ported_from": "ws/sparkz-launch-readiness (PR #17)",
    "content_hash": "sha256:cdeda3e3123281a15767929a85e81d1424c16fb0af64bc0cd34c4363da6fe0ba"
  }
}
