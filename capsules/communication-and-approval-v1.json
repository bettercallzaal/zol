{
  "schema": "dreamnet.synergy_capsule.v1",
  "capsule_id": "communication-and-approval-v1",
  "name": "Communication and Approval",
  "version": "1.0.0",
  "capsule_type": "capability_profile",
  "status": "rehearsed",
  "purpose": "Draft audience-appropriate communication and request approval without publishing automatically.",
  "payload": {
    "delivery_policy": {
      "default": "draft_only",
      "public_publish": "external_gate",
      "irreversible_send": "external_gate"
    }
  },
  "permissions": {
    "allowed": [
      "approval.request",
      "communication.draft",
      "inbox.read",
      "memory.read",
      "receipt.local.write"
    ],
    "blocked": [
      "cloud.mutate",
      "component.install",
      "connector.unbounded.write",
      "deployment.production.write",
      "package.install",
      "public.publish",
      "secret.value.read",
      "self.modify.live",
      "signer.change",
      "wallet.sign"
    ],
    "allowed_loops": [
      "draft-communication",
      "request-approval",
      "inbox-triage"
    ],
    "allowed_tools": [
      "state.read",
      "receipt.write"
    ],
    "allowed_data": [
      "receipt.local",
      "memory.local",
      "inbox.local"
    ],
    "disallowed_wallets": [
      "*"
    ],
    "disallowed_signers": [
      "*"
    ],
    "disallowed_environments": []
  },
  "resource_limits": {
    "max_wall_time_ms": 600000,
    "max_steps": 40,
    "max_retries_per_step": 2
  },
  "activation": {
    "mode": "manual_review",
    "rollback_version": "disabled"
  },
  "provenance": {
    "source": "https://github.com/BrandonDucar/dreamloops",
    "content_hash": "sha256:540ae0fa5c721709e72e75cf747a955aa3d1e623d3fc041afe51fbb5036a0e59"
  }
}
